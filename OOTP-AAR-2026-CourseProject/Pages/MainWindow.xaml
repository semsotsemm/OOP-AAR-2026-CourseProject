<Window x:Class="OOTP_AAR_2026_CourseProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OOTP_AAR_2026_CourseProject"
        Title="Rewind" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F4F0"
        Icon="/Images/rewind_logo.png">

    <Window.Resources>
        <!-- Стиль NavButton -->
     
        <!-- Стиль ActiveNavButton -->
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#FFF0ED"/>
        </Style>

        <!-- Стиль карточки трека (горизонтальная) -->
        <Style x:Key="TrackCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль PlayButton -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E8462A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CC3A20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль поиска -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#EBEBE7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#1A1A18"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="#E8462A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль слайдера -->
    
    </Window.Resources>

    <Grid>
        <Grid>
            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR ========== -->
            <Border Grid.Column="0" Background="#FFFFFF"
                    BorderBrush="#EBEBE7" BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Логотип -->
                    <StackPanel DockPanel.Dock="Top" Margin="24,28,24,24">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="32" Height="32" Background="#E8462A" CornerRadius="10">
                                <Path Data="M13,10.5 C16.5,10.5 19,8.5 19,5 C19,1.5 16.5,0 13,0 H6 V10.5 V20 M12.5,10.5 L19,20"
      Stroke="White"
      StrokeThickness="1"
      Fill="Transparent"
      Stretch="Uniform"
      Width="16" Height="16"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"/>
                                </Border>
                            <TextBlock Text="Rewind" FontSize="22" FontWeight="Bold"
                                       Foreground="#1A1A18" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource HeaderFont}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Поиск -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,0,16,20">
                        <Grid>
                            <TextBox Style="{StaticResource SearchBoxStyle}"
                                     Text="" Height="42"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10 10 10 10">
                                <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
          Fill="Black"
          Stretch="Uniform"
          Width="14" Height="14"
          VerticalAlignment="Center"/>

                                <TextBlock Text="Найти музыку" 
               FontSize="13"
               Foreground="#BBBBB5" 
               Margin="8,0,0,0"
               VerticalAlignment="Center" 
               IsHitTestVisible="False"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Навигация -->
                    <StackPanel DockPanel.Dock="Top" Margin="12,0,12,0">
                        <TextBlock Text="МЕНЮ" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#BBBBB5" Margin="12,0,0,12"/>

                        <!-- Главная (активная) -->
                        <Button Style="{StaticResource ActiveNavButtonStyle}" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" Background="#E8462A" CornerRadius="8">

                                    <Path Data="M1 10 L12 1 L23 10 v1 H21 v9 a1 1 0 0 1-1 1 H4 a1 1 0 0 1-1-1 v-9 H1 z M5 10 v9 h5 v-6 h4 v6 h5 v-9 L12 4.13 z"
                                        Fill="White"
                                        Stretch="Uniform"
                                        Width="16" Height="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,1,0,0"/>
                                </Border>
                                <TextBlock Text="Главная" FontSize="14" FontWeight="Bold"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#E8462A" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Поиск -->
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" Background="#F5F4F0" CornerRadius="8">

                                    <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
                                      Fill="Black"
                                      Stretch="Uniform"
                                      Width="16" Height="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,1,0,0"/>
                                </Border>
                                <TextBlock Text="Поиск" FontSize="14"
                                           FontWeight="Regular"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#1A1A18" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Любимые -->
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" Background="#F5F4F0" CornerRadius="8">

                                    <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
      Stroke="Black"
      StrokeThickness="1.5"
      Fill="Transparent"
      Stretch="Uniform"
      Width="16" Height="16"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Margin="0,1,0,0"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"/>
                                </Border>
                                <TextBlock Text="Любимые" FontSize="14"
                                           
                                           FontWeight="Regular"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#1A1A18" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Плейлисты -->
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" Background="#F5F4F0" CornerRadius="8">

                                    <Path Data="M3 18h18 M3 12h18 M3 6h18"
      Stroke="Black"
      StrokeThickness="1.5"
      Fill="Transparent"
      Stretch="Uniform"
      Width="16" Height="16"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Margin="0,1,0,0"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"/>
                                </Border>
                                <TextBlock Text="Плейлисты" FontSize="14"
                                           
                                           FontWeight="Regular"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#1A1A18" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Профиль -->
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" Background="#F5F4F0" CornerRadius="8">
                                    <Path Data="M12 2a4 4 0 1 1-4 4 4 4 0 0 1 4-4zm0 8a7 7 0 0 0-7 7 1 1 0 0 0 1 1h12a1 1 0 0 0 1-1 7 7 0 0 0-7-7z"
      Stroke="Black"
      StrokeThickness="1"
      Fill="Transparent"
      Stretch="Uniform"
      Width="16" Height="16"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Margin="0,1,0,0"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"/>
                                </Border>
                                <TextBlock Text="Профиль" FontSize="14"
                                           
                                           FontWeight="Regular"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#1A1A18" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Плейлисты -->
                    <StackPanel DockPanel.Dock="Top" Margin="12,28,12,0">
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,14">
                            <TextBlock Text="Мои плейлисты" FontSize="14" FontWeight="Bold"
                                       Foreground="#BBBBB5"
                                           FontFamily="{StaticResource HeaderFont}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#F5F4F0" CornerRadius="6" Margin="8,0,0,0"
                                    Padding="6,3" Cursor="Hand">
                                <TextBlock Text="+ Новый" 
                                           FontWeight="Regular"
                                           FontFamily="{StaticResource HeaderFont}"
                                           FontSize="10" Foreground="#888880"/>
                            </Border>
                        </StackPanel>
                        <local:PlaylistButton Title="Chill Vibes" Subtitle="24 трека" Icon="🎵"/>
                        <local:PlaylistButton Title="Chill Vibes" Subtitle="24 трека" Icon="🎵"/>
                        <local:PlaylistButton Title="Chill Vibes" Subtitle="24 трека" Icon="🎵"/>
                    </StackPanel>

                    <!-- Профиль внизу -->
                    <Border DockPanel.Dock="Bottom" Margin="16,0,16,20"
                            Background="#F5F4F0" CornerRadius="14" Padding="12,10" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="38" Height="38" CornerRadius="19">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8462A" Offset="0"/>
                                        <GradientStop Color="#FF8C42" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="АИ" FontSize="13" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Алексей И." FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1A1A18"/>
                                <TextBlock Text="Бесплатный план" FontSize="11" Foreground="#BBBBB5"/>
                            </StackPanel>
                            <TextBlock Text="···" FontSize="18" Foreground="#BBBBB5"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                </DockPanel>
            </Border>

            <!-- ========== MAIN CONTENT ========== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F5F4F0">
                <StackPanel Margin="32,28,32,24">

                    <!-- Заголовок страницы -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Добрый вечер, Алексей" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       FontWeight="Regular" 
                                       Foreground="#888880" Margin="0,0,0,6"/>
                            <TextBlock Text="Главная" FontSize="30" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="#1A1A18" />
                        </StackPanel>

                        <!-- Кнопка уведомлений -->
                        <Border Grid.Column="1" Width="42" Height="42" Background="#FFFFFF"
                                CornerRadius="21" Cursor="Hand" VerticalAlignment="Center">
                            <TextBlock Text="🔔" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Border CornerRadius="20" Margin="0,0,0,32" Height="180" Cursor="Hand">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8462A" Offset="0"/>
                                <GradientStop Color="#FF8C42" Offset="0.5"/>
                                <GradientStop Color="#FFD166" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="28,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <Border Background="#03fc07" CornerRadius="6" Padding="10,5"
                                        HorizontalAlignment="Left" Margin="0,0,0,0">
                                    <TextBlock Text="🔥 Трек дня" FontSize="11" FontWeight="Bold"
                                                FontFamily="{StaticResource HeaderFont}"
                                               Foreground="White"/>
                                </Border>
                                <TextBlock Text="Blinding Lights" FontSize="26" FontWeight="Bold"
                                            FontFamily="{StaticResource HeaderFont}"
                                           Foreground="White"  Margin="0 5 0 0"/>
                                <TextBlock Text="The Weeknd · 2024 Remaster" FontSize="14"
                                           
                                            FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#FFFFFF99" Margin="0,6,0,16"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="White" CornerRadius="20" Padding="18,8"
                                            Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▶" FontSize="12" Foreground="#E8462A"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text=" Слушать" FontSize="13" FontWeight="SemiBold"
                                                       
                                            FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="#E8462A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#03fc07" CornerRadius="20" Padding="14,8"
                                            Margin="10,0,0,0" Cursor="Hand">
                                        <TextBlock Text="♡  В любимые" FontSize="13" Foreground="White"
                                                   
                                            FontFamily="{StaticResource HeaderFont}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <!-- Визуализация обложки -->
                            <Border Grid.Column="1" Width="120" Height="120" CornerRadius="16"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1A18" Offset="0"/>
                                        <GradientStop Color="#333330" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="♪" FontSize="48" Foreground="#E8462A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Margin="0,0,0,28">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Рекомендации для вас" FontSize="20" FontWeight="Bold"
                                       Foreground="#1A1A18" 
                                       FontFamily="{StaticResource HeaderFont}"/>
                            <TextBlock Text="Все →" FontSize="13" Foreground="#E8462A"
                                       
                                       FontFamily="{StaticResource HeaderFont}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Cursor="Hand"/>
                        </Grid>
                        <StackPanel x:Name="MusicContainer" Margin="0,16,0,0">
                        </StackPanel>
                    </StackPanel>

                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Новые альбомы" FontSize="20" FontWeight="Bold"
                                       Foreground="#1A1A18" 
                                       FontFamily="{StaticResource HeaderFont}"/>
                            <TextBlock Text="Все →" FontSize="13" Foreground="#E8462A"
                                       
                                       FontFamily="{StaticResource HeaderFont}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Cursor="Hand"/>
                        </Grid>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden" Height="210">
                            <StackPanel Orientation="Horizontal">

                                <local:AlbumCard AlbumTitle="Midnights" 
                                     Artist="Taylor Swift" 
                                     StartColor="#11998e" 
                                     EndColor="#38ef7d" />
                                <local:AlbumCard AlbumTitle="Midnights" 
                                     Artist="Taylor Swift" 
                                     StartColor="#11998e" 
                                     EndColor="#38ef7d" />
                                <local:AlbumCard AlbumTitle="Midnights" 
                                     Artist="Taylor Swift" 
                                     StartColor="#11998e" 
                                     EndColor="#38ef7d" />
                                <local:AlbumCard AlbumTitle="Midnights" 
                                     Artist="Taylor Swift" 
                                     StartColor="#11998e" 
                                     EndColor="#38ef7d" />
                                <local:AlbumCard AlbumTitle="Midnights" 
                                     Artist="Taylor Swift" 
                                     StartColor="#11998e" 
                                     EndColor="#38ef7d" />

                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
            </Grid>
        </Grid>

        <local:PlayerBar VerticalAlignment="Bottom" 
                     Height="88"
                     CurrentTrack="As It Was" 
                     CurrentArtist="Harry Styles" />
    </Grid>
</Window>
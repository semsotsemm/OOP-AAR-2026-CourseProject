<UserControl x:Class="OOTP_AAR_2026_CourseProject.TrackItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="800">

    <Border Style="{StaticResource TrackCardStyle}">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.04"
                              BlurRadius="12" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="10" Margin="0,0,14,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="♪" FontSize="20" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TrackTitle" Text="Название трека" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1A1A18"/>
                <TextBlock x:Name="ArtistName" Text="Исполнитель" FontSize="12" Foreground="#888880"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <TextBlock Grid.Column="2" Text="♡" FontSize="18"
                       Foreground="#DEDEDA" VerticalAlignment="Center"
                       Margin="0,0,14,0" Cursor="Hand"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock x:Name="DurationText" Text="0:00" FontSize="12" Foreground="#BBBBB5"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Button Style="{StaticResource PlayButtonStyle}" Click="Play_Click">
                    <TextBlock Text="▶" FontSize="12" Foreground="White"
                               Margin="2,0,0,0"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
<UserControl x:Class="OOTP_AAR_2026_CourseProject.PlayerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="thisPlayer">

    <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0">
        <Border.Background>
            <SolidColorBrush Color="#1A1A18" Opacity="0.6"/>
        </Border.Background>

    <Grid Margin="24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="10" Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F093FB" Offset="0"/>
                            <GradientStop Color="#F5576C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🎵" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTrack, ElementName=thisPlayer}" 
                               FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="{Binding CurrentArtist, ElementName=thisPlayer}" 
                               FontSize="12" Foreground="#888880" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock Text="♥" FontSize="18" Foreground="#E8462A"
                           Margin="18,0,0,0" VerticalAlignment="Center" Cursor="Hand"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="⇄" Style="{StaticResource PlayerControlBtnStyle}"/>
                    <Button Content="⏮" Style="{StaticResource PlayerControlBtnStyle}"/>

                    <Button Click="PlayButton_Click" Background="Transparent" BorderThickness="0">
                        <Border Width="44" Height="44" Background="White" CornerRadius="22">
                            <TextBlock Text="{Binding PlayPauseIcon, ElementName=thisPlayer}" 
                                       FontSize="18" Foreground="#1A1A18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>

                    <Button Content="⏭" Style="{StaticResource PlayerControlBtnStyle}"/>
                    <Button Content="↺" Style="{StaticResource PlayerControlBtnStyle}"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="1:14" FontSize="11" Foreground="#888880" HorizontalAlignment="Center"/>
                    <Slider Grid.Column="1" Style="{StaticResource SliderStyle}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="2:37" FontSize="11" Foreground="#888880" HorizontalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="🔊" FontSize="16" Foreground="#888880" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider Style="{StaticResource SliderStyle}" Width="100" VerticalAlignment="Center" Value="70"/>
                <TextBlock Text="⋮⋮" FontSize="16" Foreground="#888880" VerticalAlignment="Center" Margin="18,0,0,0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
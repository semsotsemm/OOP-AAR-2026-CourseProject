<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:help="clr-namespace:Rewind.Helpers">


    <help:FileNameToIconConverter x:Key="FileNameToIconConverter"/>
    <!-- Кнопки панели навигации -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                          CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F5F4F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleSwitch — красивый тумблер вместо стандартного чекбокса -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="44" Height="24">
                        <!-- Дорожка -->
                        <Border x:Name="Track" CornerRadius="12"
                            Background="#DDDDD8" Width="44" Height="24"/>
                        <!-- Кружок -->
                        <Border x:Name="Thumb" Width="18" Height="18"
                            CornerRadius="9" Background="White"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="3,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                              Opacity="0.2" Direction="270"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="#38C96A"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="23,0,0,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GreenSliderStyle — стильный слайдер под цвет приложения -->
    <Style x:Key="GreenSliderStyle" TargetType="Slider">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Track x:Name="PART_Track" Grid.Row="1">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" CornerRadius="2" Background="#38C96A"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" CornerRadius="2" Background="#E0DFD9"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid>
                                                <Ellipse Width="18" Height="18" Fill="White">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="2"
                                                                      Opacity="0.2" Direction="270"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <Ellipse Width="8" Height="8" Fill="#38C96A"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Активный элемент меню -->
    <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource ActiveCardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        <Setter Property="BorderThickness" Value="1.5"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="MainBorder" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="14" 
                        Padding="10,5">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Табы профиля — неактивная -->
    <Style x:Key="ProfileTab" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#888880"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="9">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Табы профиля — активная -->
    <Style x:Key="ProfileTabActive" TargetType="Button" BasedOn="{StaticResource ProfileTab}">
        <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Строка трека -->
    <Style x:Key="TrackRow" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderBrush" Value="#E0DFD9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Строка настроек -->
    <Style x:Key="SettingsRow" TargetType="Border">
        <Setter Property="Padding" Value="18,14"/>
        <Setter Property="BorderBrush" Value="#E0DFD9"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Карточка плейлиста -->
    <Style x:Key="PlaylistCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderBrush" Value="#E0DFD9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Карточка статистики -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="16,14"/>
    </Style>

    <!-- Тоггл -->
    <Style x:Key="ToggleOff" TargetType="Border">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Background" Value="#D0CFC9"/>
        <Setter Property="CornerRadius" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style x:Key="ToggleOn" TargetType="Border" BasedOn="{StaticResource ToggleOff}">
        <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
    </Style>

    <!-- Карточка темы -->
    <Style x:Key="ThemeCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>
    <Style x:Key="ThemeCardActive" TargetType="Border" BasedOn="{StaticResource ThemeCard}">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
    </Style>
    
    <!-- Ползунки -->
    <Style x:Key="SliderStyle" TargetType="Slider">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" Background="{DynamicResource AccentColor}" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="12" Height="12" Fill="White" StrokeThickness="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" Background="#DEDEDA" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопки панели плеера -->
    <Style x:Key="PlayerControlBtnStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Foreground" Value="#888880"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка плей -->
    <Style x:Key="PlayButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <!-- Кнопки динамического острова -->
    <Style x:Key="PlayerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#AAAAAA"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Стиль поиска -->
    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderBrush" Value="#EBEBE7"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Foreground" Value="#1A1A18"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CaretBrush" Value="#E8462A"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль поля ввода -->
    <Style x:Key="InputField" TargetType="TextBox">
        <Setter Property="Height" Value="48"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#1A1A18"/>
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderBrush" Value="#E0DFD9"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <Grid>
                            <TextBlock x:Name="Placeholder"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="#BBBBB5"
                                   FontSize="14"
                                   Padding="16,0"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль поля пароля -->
    <Style x:Key="PasswordField" TargetType="PasswordBox">
        <Setter Property="Height" Value="48"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#1A1A18"/>
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="BorderBrush" Value="#E0DFD9"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ScrollViewer x:Name="PART_ContentHost"
                                  Padding="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка главная красная -->
    <Style x:Key="BtnRed" TargetType="Button">
        <Setter Property="Height" Value="50"/>
        <Setter Property="Background" Value="#23C13A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#C23520"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка тёмная -->
    <Style x:Key="BtnDark" TargetType="Button" BasedOn="{StaticResource BtnRed}">
        <Setter Property="Background" Value="#1A1A18"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#333330"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Метка поля -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#BBBBB5"/>
        <Setter Property="Margin" Value="0,0,0,7"/>
    </Style>


    <!-- Роли в меню регистрации -->
    <!-- Роли в меню регистрации -->
    <Style x:Key="RoleCardButtonStyle" TargetType="ListBoxItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="MainBorder" 
                            Background="#F5F4F0" 
                            BorderBrush="#E0DFD9" 
                            BorderThickness="1.5" 
                            CornerRadius="14" 
                            Cursor="Hand" 
                            Padding="14,16"
                            Margin="5">
                        <StackPanel HorizontalAlignment="Center">
                            <Border x:Name="IconContainer" Width="40" Height="40" CornerRadius="10" 
                                    Background="{DynamicResource DefaultIconBackground}" 
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Rectangle x:Name="IconRect"
                                       Width="18" Height="18"
                                       Fill="#1A1A18"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource FileNameToIconConverter}}"
                                                Stretch="Uniform"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Border>
                            <TextBlock x:Name="LabelText" 
                                       Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                       FontSize="13" FontWeight="Bold" 
                                       Foreground="{DynamicResource DefaultSecondaryText}" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DescText" 
                                       Text="{Binding ToolTip, RelativeSource={RelativeSource TemplatedParent}}" 
                                       FontSize="11" Foreground="#BBBBB5" 
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource ActiveCardBackground}"/>
                            <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource AccentColor}"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            <Setter TargetName="IconRect" Property="Fill" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernToggleStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="BackgroundBorder" 
                        Width="44" Height="26" 
                        CornerRadius="13" 
                        Background="#D0CFC9">
                        <Ellipse x:Name="Dot" 
                             Width="20" Height="20" 
                             Fill="White" 
                             HorizontalAlignment="Left" 
                             Margin="3,0,0,0">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Dot" 
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                     To="18" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Dot" 
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                     To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка режима (Войти/Регистрация) -->
    <Style x:Key="ModeBtn" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#888880"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="9">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3A3A3A"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <Style x:Key="ModeBtnActive" TargetType="Button" BasedOn="{StaticResource ModeBtn}">
        <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
        <Setter Property="Foreground" Value="#1A1A18"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
</ResourceDictionary>
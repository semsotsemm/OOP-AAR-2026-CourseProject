<Window x:Class="Rewind.Pages.Playlists"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Rewind"
        Title="Rewind — Плейлисты"
        Icon="/Images/rewind_logo.png"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgMain}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Логотип -->
                <StackPanel DockPanel.Dock="Top" Margin="24,28,24,24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="20" ClipToBounds="True" Margin="0,0,10,0">
                            <Image Source="/Images/rewind_logo.png" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="Rewind" VerticalAlignment="Center"
                                   FontFamily="{StaticResource HeaderFont}"
                                   FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Поиск -->
                <StackPanel DockPanel.Dock="Top" Margin="16,0,16,20">
                    <Grid>
                        <TextBox Style="{StaticResource SearchBoxStyle}" Height="42"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                            <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
                                  Fill="{StaticResource TextMuted}" Stretch="Uniform" Width="14" Height="14"/>
                            <TextBlock Text="Найти музыку" FontSize="13" Foreground="{StaticResource TextMuted}"
                                       Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Навигация -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0,12,0">
                    <TextBlock Text="МЕНЮ" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="12,0,0,12"/>

                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="{StaticResource BgMain}" CornerRadius="8">
                                <Path Data="M1 10 L12 1 L23 10 v1 H21 v9 a1 1 0 0 1-1 1 H4 a1 1 0 0 1-1-1 v-9 H1 z"
                                      Fill="{StaticResource TextPrimary}" Stretch="Uniform" Width="16" Height="16"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Главная" FontSize="14" FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{StaticResource TextPrimary}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="{StaticResource BgMain}" CornerRadius="8">
                                <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
                                      Fill="{StaticResource TextPrimary}" Stretch="Uniform" Width="16" Height="16"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Поиск" FontSize="14" FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{StaticResource TextPrimary}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="{StaticResource BgMain}" CornerRadius="8">
                                <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                      Stroke="{StaticResource TextPrimary}" StrokeThickness="1.5" Fill="Transparent"
                                      Stretch="Uniform" Width="16" Height="16"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Любимые" FontSize="14" FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{StaticResource TextPrimary}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Плейлисты — АКТИВНЫЙ -->
                    <Button Style="{StaticResource ActiveNavButtonStyle}" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="{StaticResource AccentColor}" CornerRadius="8">
                                <Path Data="M3 18h18 M3 12h18 M3 6h18"
                                      Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                                      Stretch="Uniform" Width="16" Height="16"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Плейлисты" FontSize="14" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{StaticResource AccentColor}"
                                       Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="{StaticResource BgMain}" CornerRadius="8">
                                <Path Data="M12 2a4 4 0 1 1-4 4 4 4 0 0 1 4-4zm0 8a7 7 0 0 0-7 7 1 1 0 0 0 1 1h12a1 1 0 0 0 1-1 7 7 0 0 0-7-7z"
                                      Fill="{StaticResource TextPrimary}" Stretch="Uniform" Width="16" Height="16"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Профиль" FontSize="14" FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{StaticResource TextPrimary}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Мои плейлисты в сайдбаре -->
                <StackPanel DockPanel.Dock="Top" Margin="12,28,12,0">
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,14">
                        <TextBlock Text="Мои плейлисты" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource BgMain}" CornerRadius="6"
                                Margin="8,0,0,0" Padding="6,3" Cursor="Hand">
                            <TextBlock Text="+ Новый" FontSize="10" Foreground="{StaticResource TextSecondary}"
                                       FontFamily="{StaticResource HeaderFont}"/>
                        </Border>
                    </StackPanel>
                    <local:PlaylistButton Title="Chill Vibes" Subtitle="24 трека" Icon="🎵"/>
                    <local:PlaylistButton Title="Рок-классика" Subtitle="18 треков" Icon="🎸"/>
                    <local:PlaylistButton Title="Ночная Drive" Subtitle="31 трек" Icon="🌙"/>
                </StackPanel>

                <!-- Профиль внизу -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,20"
                        Background="{StaticResource BgMain}" CornerRadius="14"
                        Padding="12,10" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38" CornerRadius="19">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2AE876" Offset="0"/>
                                    <GradientStop Color="#23C13A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="АИ" FontSize="13" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Алексей И." FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Бесплатный план" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBlock Text="···" FontSize="18" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Заголовок + кнопка создать -->
                <RowDefinition Height="Auto"/>
                <!-- Тело: список плейлистов слева + треки плейлиста справа -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="{StaticResource BgSidebar}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                    Padding="32,22,32,22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Плейлисты" FontSize="28" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="12 плейлистов · 247 треков" FontSize="13"
                                   Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Кнопка создать новый -->
                    <Border Grid.Column="1" Background="{StaticResource AccentColor}"
                            CornerRadius="12" Padding="20,12" Cursor="Hand" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Новый плейлист" FontSize="14" FontWeight="Bold"
                                       Foreground="White" FontFamily="{StaticResource HeaderFont}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Тело: левая панель + правая панель -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Список плейлистов -->
                    <ColumnDefinition Width="320"/>
                    <!-- Содержимое выбранного плейлиста -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== ЛЕВАЯ: список всех плейлистов ===== -->
                <Border Grid.Column="0" Background="{StaticResource BgSidebar}"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- Фильтр / Поиск по плейлистам -->
                        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,12">
                            <Grid>
                                <TextBox Style="{StaticResource SearchBoxStyle}" Height="40"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                    <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
                                          Fill="{StaticResource TextMuted}" Stretch="Uniform" Width="13" Height="13"/>
                                    <TextBlock Text="Поиск плейлиста..." FontSize="13"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Список плейлистов -->
                        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,12,12">

                                <!-- Плейлист — АКТИВНЫЙ -->
                                <Border Background="{StaticResource AccentLight}" CornerRadius="14"
                                        BorderBrush="{StaticResource AccentColor}" BorderThickness="1.5"
                                        Padding="14,12" Margin="0,0,0,8" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#004D40" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="🎵" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Chill Vibes" FontSize="14" FontWeight="Bold"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="24 трека · 1ч 32м" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="···" FontSize="18"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Плейлисты — обычные -->
                                <Border Style="{StaticResource PlaylistCard}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#E8462A" Offset="0"/>
                                                    <GradientStop Color="#FF8C42" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="🎸" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Рок-классика" FontSize="14" FontWeight="Bold"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="18 треков · 1ч 12м" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="···" FontSize="18"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource PlaylistCard}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#667EEA" Offset="0"/>
                                                    <GradientStop Color="#764BA2" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="🌙" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Ночная Drive" FontSize="14" FontWeight="Bold"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="31 трек · 2ч 08м" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="···" FontSize="18"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource PlaylistCard}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                Margin="0,0,14,0" Background="{StaticResource TextPrimary}">
                                            <TextBlock Text="💼" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Для работы" FontSize="14" FontWeight="Bold"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="15 треков · 58м" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="···" FontSize="18"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource PlaylistCard}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#11998E" Offset="0"/>
                                                    <GradientStop Color="#38EF7D" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="🌿" FontSize="20"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Утренний ритм" FontSize="14" FontWeight="Bold"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="20 треков · 1ч 18м" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="···" FontSize="18"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ===== ПРАВАЯ: содержимое плейлиста ===== -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{StaticResource BgMain}">
                    <StackPanel Margin="32,28,32,120">

                        <!-- Шапка плейлиста -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Обложка -->
                            <Border Grid.Column="0" Width="160" Height="160" CornerRadius="20"
                                    Margin="0,0,28,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2AE876" Offset="0"/>
                                        <GradientStop Color="#004D40" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🎵" FontSize="64"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Информация -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <Border Background="{StaticResource AccentColor}" CornerRadius="6"
                                        Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <TextBlock Text="ПЛЕЙЛИСТ" FontSize="10" FontWeight="Bold"
                                               Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                                </Border>
                                <TextBlock Text="Chill Vibes" FontSize="32" FontWeight="Black"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                                <TextBlock Text="Алексей И. · 24 трека · 1ч 32м" FontSize="14"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

                                <!-- Кнопки управления -->
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource AccentColor}" CornerRadius="24"
                                            Padding="24,12" Cursor="Hand" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M8 5v14l11-7z" Fill="White" Stretch="Uniform"
                                                  Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Слушать" FontSize="14" FontWeight="Bold"
                                                       Foreground="White" FontFamily="{StaticResource HeaderFont}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BgSidebar}" CornerRadius="24"
                                            Padding="20,12" Cursor="Hand"
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M17 1l4 4-4 4M3 11V9a4 4 0 0 1 4-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 0 1-4 4H3"
                                                  Stroke="{StaticResource TextPrimary}" StrokeThickness="1.5"
                                                  Fill="Transparent" Stretch="Uniform"
                                                  Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Перемешать" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BgSidebar}" CornerRadius="24"
                                            Padding="20,12" Cursor="Hand"
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                        <TextBlock Text="···" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Заголовок таблицы -->
                        <Grid Margin="0,0,0,8" Opacity="0.6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="НАЗВАНИЕ" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="52,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="АЛЬБОМ" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Grid.Column="3" Text="ДАТА" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Grid.Column="4" Text="⏱" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderColor}" Margin="0,0,0,12"/>

                        <!-- Треки плейлиста -->
                        <Border Style="{StaticResource TrackRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="1" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#E8462A" Offset="0"/>
                                                <GradientStop Color="#FF8C42" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="♪" FontSize="18" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Blinding Lights" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="The Weeknd" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

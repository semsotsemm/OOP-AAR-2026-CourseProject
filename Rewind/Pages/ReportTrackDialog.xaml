<Window x:Class="Rewind.Pages.ReportTrackDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Жалоба на трек"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgMain}">
    <StackPanel Margin="32">
        <TextBlock x:Name="TrackNameText" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   FontFamily="{StaticResource HeaderFont}"
                   TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
        <TextBlock Text="Жалоба на трек" FontSize="13"
                   Foreground="{DynamicResource TextSecondary}"
                   FontFamily="{StaticResource HeaderFont}" Margin="0,0,0,24"/>

        <TextBlock Text="Выберите причину:" FontSize="12" FontWeight="Bold"
                   Foreground="{DynamicResource TextSecondary}"
                   FontFamily="{StaticResource HeaderFont}" Margin="0,0,0,8"/>

        <ComboBox x:Name="ReasonCombo" Height="38" FontSize="13" Margin="0,0,0,16">
            <ComboBoxItem Content="Нарушение авторских прав" IsSelected="True"/>
            <ComboBoxItem Content="Ненормативная лексика без предупреждения"/>
            <ComboBoxItem Content="Оскорбительный контент"/>
            <ComboBoxItem Content="Спам или реклама"/>
            <ComboBoxItem Content="Неправильные метаданные / теги"/>
            <ComboBoxItem Content="Другое"/>
        </ComboBox>

        <TextBlock Text="Дополнительно (необязательно):" FontSize="12" FontWeight="Bold"
                   Foreground="{DynamicResource TextSecondary}"
                   FontFamily="{StaticResource HeaderFont}" Margin="0,0,0,8"/>
        <TextBox x:Name="DetailBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                 FontSize="13" Padding="10"
                 FontFamily="{StaticResource BodyFont}"
                 Foreground="{DynamicResource TextPrimary}"
                 Background="{DynamicResource BgCard}"
                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,24"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Click="Cancel_Click"
                    Background="{DynamicResource BgCardHover}"
                    Foreground="{DynamicResource TextSecondary}"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Padding="18,10" Margin="0,0,12,0" Cursor="Hand"/>
            <Button Content="Отправить жалобу" Click="Submit_Click"
                    Background="#FFEAEA" Foreground="#C62828"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Padding="18,10" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>

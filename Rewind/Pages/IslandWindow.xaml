<Window x:Class="Rewind.IslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewind" Height="60" Width="320"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        Icon="/Images/rewind_logo.png"
        Focusable="True">
    <Grid>
        <Border x:Name="RootBorder" CornerRadius="0,0,25,25" BorderBrush="#33FFFFFF" BorderThickness="0,0,1,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CC667EEA" Offset="0"/>
                    <GradientStop Color="#CC764BA2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <Grid Margin="15,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="AlbumArtContainer" Grid.Column="0" CornerRadius="6" Width="38" Height="38" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#667EEA" Offset="0"/>
                            <GradientStop Color="#764BA2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <TextBlock Text="♪" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"/>
                        <Image x:Name="AlbumArt" Stretch="UniformToFill">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,38,38" RadiusX="6" RadiusY="6"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="TrackTitle" Text="Название трека" Foreground="White" 
                               FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ArtistName" Text="Исполнитель" Foreground="#DDFFFFFF" 
                               FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⏮" Click="Prev_Click" Style="{StaticResource PlayerButtonStyle}"/>
                    <Button x:Name="PlayPauseBtn" Content="⏸" Click="Pause_Click" Style="{StaticResource PlayerButtonStyle}" FontSize="18"/>
                    <Button Content="⏭" Click="Next_Click" Style="{StaticResource PlayerButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
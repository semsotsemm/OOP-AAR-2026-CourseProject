<Window x:Class="Rewind.IslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewind" Height="65" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        Icon="/Images/rewind_logo.png"
        Focusable="True">
    <Grid>
        <Border x:Name="RootBorder" CornerRadius="0,0,20,20" BorderBrush="#33FFFFFF" BorderThickness="0,0,1,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A1A1A" Offset="0"/>
                    <GradientStop Color="#FF2D2D2D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="3" Opacity="0.5"/>
            </Border.Effect>

            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="AlbumArtContainer" Grid.Column="0" 
                        CornerRadius="8" Width="45" Height="45" 
                        VerticalAlignment="Center" Background="#FF333333">
                    <Grid>
                        <TextBlock Text="♪" Foreground="White" VerticalAlignment="Center" 
                                   HorizontalAlignment="Center" Opacity="0.4" FontSize="18"/>
                        <Image x:Name="AlbumArt" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="NearestNeighbor">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,45,45" RadiusX="8" RadiusY="8"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="TrackTitle" Text="Название трека" Foreground="White" 
                               FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ArtistName" Text="Исполнитель" Foreground="#FFAAAAAA" 
                               FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⏮" Click="Prev_Click" Style="{StaticResource PlayerButtonStyle}" Cursor="Hand"/>
                    <Button x:Name="PlayPauseBtn" Content="⏸" Click="Pause_Click" 
                            Style="{StaticResource PlayerButtonStyle}" FontSize="20" Margin="4,0" Cursor="Hand"/>
                    <Button Content="⏭" Click="Next_Click" Style="{StaticResource PlayerButtonStyle}" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
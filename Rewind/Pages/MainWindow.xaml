<Window x:Class="Rewind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewind - DB Test Admin Panel" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F4F0">
    <Grid Margin="10">
        <TabControl x:Name="MainTabControl" Background="White">

            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Новый пользователь" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="UserNickname" Text="Nickname" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="UserEmail" Text="Email" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="UserPassword" Text="Password" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="UserRole" Text="RoleID (1, 2, 3)" Margin="0,0,0,10" Padding="2"/>

                        <Button x:Name="btnAddUser" Content="Добавить" Click="RegisterNewUser" Height="30" Margin="0,0,0,5" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnUpdateUser" Content="Обновить выбранного" Click="UpdateUser" Height="30" Margin="0,0,0,5"/>
                        <Button x:Name="btnDeleteUser" Content="Удалить выбранного" Height="30" Margin="0,0,0,15" Background="#F44336" Foreground="White"/>

                        <Separator Margin="0,10"/>
                        <Button x:Name="btnLoadUsers" Content="Загрузить список" Height="40" Background="#2196F3" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="dgUsers" Grid.Column="1" AutoGenerateColumns="True" IsReadOnly="True" HeadersVisibility="Column"/>
                </Grid>
            </TabItem>

            <TabItem Header="Треки">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Новый трек" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtTrackTitle" Text="Title" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtTrackFilePath" Text="File Path (/path/to/file)" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtTrackArtistId" Text="Artist ID" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtTrackDuration" Text="Duration (sec)" Margin="0,0,0,10" Padding="2"/>

                        <Button x:Name="btnAddTrack" Content="Добавить трек" Height="30" Margin="0,0,0,5" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnDeleteTrack" Content="Удалить выбранный" Height="30" Margin="0,0,0,15" Background="#F44336" Foreground="White"/>

                        <Separator Margin="0,10"/>
                        <TextBlock Text="Статистика трека (ID):" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtStatTrackId" Margin="0,0,0,5" Padding="2"/>
                        <Button x:Name="btnIncPlay" Content="+1 Прослушивание" Margin="0,0,0,5"/>
                        <Button x:Name="btnIncLike" Content="+1 Лайк" Margin="0,0,0,15"/>

                        <Button x:Name="btnLoadTracks" Content="Загрузить список треков" Height="40" Background="#2196F3" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="dgTracks" Grid.Column="1" AutoGenerateColumns="True" IsReadOnly="True" HeadersVisibility="Column"/>
                </Grid>
            </TabItem>

            <TabItem Header="Плейлисты">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Создать плейлист" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtPlaylistTitle" Text="Playlist Title" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtPlaylistOwnerId" Text="Owner ID" Margin="0,0,0,10" Padding="2"/>

                        <Button x:Name="btnAddPlaylist" Content="Создать" Height="30" Margin="0,0,0,5" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnDeletePlaylist" Content="Удалить выбранный" Height="30" Margin="0,0,0,15" Background="#F44336" Foreground="White"/>

                        <Separator Margin="0,10"/>
                        <TextBlock Text="Добавить трек в плейлист:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtPtPlaylistId" Text="Playlist ID" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtPtTrackId" Text="Track ID" Margin="0,0,0,10" Padding="2"/>
                        <Button x:Name="btnAddTrackToPlaylist" Content="Привязать трек" Height="30" Margin="0,0,0,15"/>

                        <Button x:Name="btnLoadPlaylists" Content="Загрузить плейлисты" Height="40" Background="#2196F3" Foreground="White"/>
                    </StackPanel>

                    <DataGrid x:Name="dgPlaylists" Grid.Column="1" AutoGenerateColumns="True" IsReadOnly="True" HeadersVisibility="Column"/>
                </Grid>
            </TabItem>

            <TabItem Header="Связи (Подписки / Избранное)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Тест подписок" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBox x:Name="txtFollowerId" Text="Follower User ID" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtArtistIdToFollow" Text="Artist User ID" Margin="0,0,0,10" Padding="2"/>

                        <Button x:Name="btnSubscribe" Content="Подписаться" Height="30" Margin="0,0,0,5" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnUnsubscribe" Content="Отписаться" Height="30" Margin="0,0,0,15" Background="#F44336" Foreground="White"/>

                        <Button x:Name="btnLoadFollowers" Content="Показать подписчиков артиста" Height="30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="Тест Избранного (Лайки)" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBox x:Name="txtFavUserId" Text="User ID" Margin="0,0,0,5" Padding="2"/>
                        <TextBox x:Name="txtFavTrackId" Text="Track ID" Margin="0,0,0,10" Padding="2"/>

                        <Button x:Name="btnLikeTrack" Content="Добавить в избранное" Height="30" Margin="0,0,0,5" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnUnlikeTrack" Content="Убрать из избранного" Height="30" Margin="0,0,0,15" Background="#F44336" Foreground="White"/>

                        <Button x:Name="btnLoadFavorites" Content="Показать избранное юзера" Height="30"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
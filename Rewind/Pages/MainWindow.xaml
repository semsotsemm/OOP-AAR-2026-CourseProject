<Window x:Class="Rewind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rewind"
        xmlns:controls="clr-namespace:Rewind.Contols"
        mc:Ignorable="d"
        Title="Rewind"
        Icon="/Images/rewind_logo.png"
        Height="780" Width="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">

                <!-- Логотип -->
                <StackPanel DockPanel.Dock="Top" Margin="24,26,24,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0">
                            <Image Source="/Images/rewind_logo.png" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="Rewind" VerticalAlignment="Center"
                                   FontWeight="Black" FontSize="16" Foreground="#1A1A18"
                                   FontFamily="{StaticResource HeaderFont}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Навигация -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0,12,0">
                    <TextBlock Text="МЕНЮ" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMuted}" Margin="12,0,0,10"/>

                    <Button Style="{StaticResource NavButtonStyle}" Click="ShowHome_Click" x:Name="BtnHome">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Главная" FontSize="13" Foreground="#888880" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}" x:Name="BtnSearch">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Поиск" FontSize="13" Foreground="#888880" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}" x:Name="BtnFavorites" Click="ShowLiked_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                      Stroke="#888880" StrokeThickness="1.5" Fill="Transparent"
                                      Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Любимые" FontSize="13" Foreground="#888880" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPlaylists" Style="{StaticResource NavButtonStyle}" Click="ShowPlaylists_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M3 18h18 M3 12h18 M3 6h18"
                                      Stroke="#888880" StrokeThickness="1.5" Fill="Transparent"
                                      Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Плейлисты" FontSize="13" Foreground="#888880" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ПРОФИЛЬ — активный -->
                    <Button x:Name="BtnProfile" Style="{StaticResource ActiveNavButtonStyle}" Click="ShowProfile_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="{DynamicResource AccentColor}" Margin="0,0,10,0">
                                <Path Data="M12 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8zm0 10c5 0 8 2.24 8 4v1H4v-1c0-1.76 3-4 8-4z"
                                      Fill="White" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Профиль" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
        <ContentControl x:Name="MainContentArea" Grid.Column="1" Grid.Row="0" />
        <controls:PlayerBar x:Name="GlobalPlayerBar"
                            Grid.Column="1"
                            Grid.Row="1"
                            Height="100"
                            Visibility="Collapsed"
                            Panel.ZIndex="50"/>
    </Grid>
</Window>
<Window x:Class="Rewind.Pages.NowPlaying"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewind — Сейчас играет"
        Icon="/Images/rewind_logo.png"
        Height="780" Width="1280"
        WindowStartupLocation="CenterOwner"
        Background="#101010">
    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush x:Name="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF222222" Offset="0"/>
                <GradientStop Color="#FF111111" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="24" HorizontalAlignment="Center" MaxWidth="1500">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="BackButton" Grid.Row="0" Background="#2A2A28" CornerRadius="12" Padding="12,8"
                    HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonDown="BackButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="←" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="BackText" Text="Назад" Foreground="White" FontWeight="SemiBold" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="900"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="430"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="760">
                    <Border Width="380" Height="380" CornerRadius="24" ClipToBounds="True" Margin="0,0,0,18">
                        <Border.Effect>
                            <DropShadowEffect Color="#AA000000" BlurRadius="28" ShadowDepth="4" Opacity="0.55"/>
                        </Border.Effect>
                        <Grid>
                            <Image x:Name="CoverImage" Stretch="UniformToFill"/>
                            <TextBlock x:Name="CoverPlaceholder" Text="♪" FontSize="96" Foreground="#CCFFFFFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="TrackTitleText" Text="Название трека" FontSize="32" FontWeight="Black"
                               Foreground="White" TextAlignment="Center"/>
                    <TextBlock x:Name="TrackArtistText" Text="Исполнитель" FontSize="16" Foreground="#E4E4E0"
                               TextAlignment="Center" Margin="0,8,0,18"/>

                    <Grid Width="700" Margin="0,0,0,6">
                        <Slider x:Name="ProgressSlider" Minimum="0" Maximum="1" Value="0" ValueChanged="ProgressSlider_ValueChanged"
                                PreviewMouseDown="ProgressSlider_PreviewMouseDown" PreviewMouseUp="ProgressSlider_PreviewMouseUp"/>
                    </Grid>
                    <Grid Width="700" Margin="0,0,0,20">
                        <TextBlock x:Name="CurrentTimeText" Text="0:00" Foreground="#E4E4E0"/>
                        <TextBlock x:Name="TotalTimeText" Text="0:00" Foreground="#E4E4E0" HorizontalAlignment="Right"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Button x:Name="ShuffleBtn" Width="46" Height="46" Margin="0,0,12,0" Background="#2A2A28" BorderThickness="0" Foreground="#E4E4E0" Click="ShuffleBtn_Click">🔀</Button>
                        <Button Width="56" Height="56" Margin="0,0,12,0" Background="#2A2A28" BorderThickness="0" Foreground="White" Click="PrevBtn_Click">⏮</Button>
                        <Button x:Name="PlayPauseBtn" Width="72" Height="72" Margin="0,0,12,0" Background="{DynamicResource AccentColor}" BorderThickness="0" Foreground="White" FontSize="24" Click="PlayPauseBtn_Click">⏸</Button>
                        <Button Width="56" Height="56" Margin="0,0,12,0" Background="#2A2A28" BorderThickness="0" Foreground="White" Click="NextBtn_Click">⏭</Button>
                        <Button x:Name="RepeatBtn" Width="46" Height="46" Background="#2A2A28" BorderThickness="0" Foreground="#E4E4E0" Click="RepeatBtn_Click">🔁</Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🔊" FontSize="16" Foreground="#E4E4E0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="VolumeSlider" Width="220" Minimum="0" Maximum="1" ValueChanged="VolumeSlider_ValueChanged"/>
                        <Border x:Name="LikeBtn" Background="#2A2A28" CornerRadius="16" Margin="18,0,0,0" Padding="10,6" Cursor="Hand" MouseLeftButtonDown="LikeBtn_Click">
                            <TextBlock x:Name="LikeText" Text="♡" FontSize="20" Foreground="#2AE876"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2" Background="#22000000" CornerRadius="20" Padding="16">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Очередь" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="QueuePanel"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
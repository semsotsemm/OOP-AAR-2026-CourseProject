<Window x:Class="Rewind.Pages.NowPlaying"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Rewind"
        Title="Rewind — Сейчас играет"
        Icon="/Images/rewind_logo.png"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PlayerBg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Левая: обложка + управление -->
            <ColumnDefinition Width="420"/>
            <!-- Центр: информация + ползунок + очередь -->
            <ColumnDefinition Width="*"/>
            <!-- Правая: текст песни -->
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== ЛЕВАЯ ПАНЕЛЬ ===================== -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A1A18" Offset="0"/>
                    <GradientStop Color="#0D0D0C" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" Margin="36,0">

                <!-- Кнопка назад -->
                <Button Style="{StaticResource PlayerControlBtnStyle}"
                        HorizontalAlignment="Left" Margin="0,0,0,32"
                        Width="Auto" Height="Auto">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19 12H5M12 5l-7 7 7 7"
                              Stroke="#888880" StrokeThickness="1.8"
                              Fill="Transparent" Stretch="Uniform"
                              Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="Назад" FontSize="13" Foreground="#888880"
                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                   FontFamily="{StaticResource HeaderFont}"/>
                    </StackPanel>
                </Button>

                <!-- Обложка -->
                <Border Width="300" Height="300" CornerRadius="24"
                        HorizontalAlignment="Center" Margin="0,0,0,32">
                    <Border.Effect>
                        <DropShadowEffect Color="#2AE876" BlurRadius="60" Opacity="0.35"
                                          ShadowDepth="0"/>
                    </Border.Effect>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1A18" Offset="0"/>
                            <GradientStop Color="#333330" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border CornerRadius="24" ClipToBounds="True">
                        <!-- Сюда можно подставить Image с реальной обложкой -->
                        <Grid>
                            <TextBlock Text="♪" FontSize="100"
                                       Foreground="{StaticResource AccentColor}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Название + артист -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TrackTitle" Text="Blinding Lights"
                                   FontSize="24" FontWeight="Black"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="White"/>
                        <TextBlock x:Name="TrackArtist" Text="The Weeknd"
                                   FontSize="15" Foreground="#888880" Margin="0,6,0,0"/>
                    </StackPanel>
                    <!-- Кнопка лайк -->
                    <Border Grid.Column="1" Width="42" Height="42" CornerRadius="21"
                            Background="#252523" VerticalAlignment="Center" Cursor="Hand">
                        <TextBlock Text="♥" FontSize="18" Foreground="{StaticResource AccentColor}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Слайдер прогресса -->
                <Grid Margin="0,0,0,6">
                    <Slider x:Name="ProgressSlider" Style="{StaticResource SliderStyle}"
                            Minimum="0" Maximum="100" Value="35"/>
                </Grid>
                <Grid Margin="0,0,0,24">
                    <TextBlock Text="1:09" FontSize="12" Foreground="#555552"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="3:20" FontSize="12" Foreground="#555552"
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- Кнопки управления -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Перемешать -->
                    <Button Grid.Column="0" Style="{StaticResource PlayerControlBtnStyle}"
                            HorizontalAlignment="Center">
                        <Path Data="M17 1l4 4-4 4M3 11V9a4 4 0 0 1 4-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 0 1-4 4H3"
                              Stroke="{StaticResource AccentColor}" StrokeThickness="1.8"
                              Fill="Transparent" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>

                    <!-- Предыдущий -->
                    <Button Grid.Column="1" Style="{StaticResource PlayerControlBtnStyle}"
                            HorizontalAlignment="Center">
                        <Path Data="M19 20L9 12l10-8v16zM5 19V5"
                              Stroke="White" StrokeThickness="1.8"
                              Fill="Transparent" Stretch="Uniform" Width="22" Height="22"/>
                    </Button>

                    <!-- Плей (большой) -->
                    <Button Grid.Column="2" HorizontalAlignment="Center" Cursor="Hand"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="64" Height="64" CornerRadius="32"
                                        Background="{DynamicResource AccentColor}">
                                    <Path Data="M8 5v14l11-7z"
                                          Fill="White" Stretch="Uniform"
                                          Width="26" Height="26"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Следующий -->
                    <Button Grid.Column="3" Style="{StaticResource PlayerControlBtnStyle}"
                            HorizontalAlignment="Center">
                        <Path Data="M5 4l10 8-10 8V4zM19 5v14"
                              Stroke="White" StrokeThickness="1.8"
                              Fill="Transparent" Stretch="Uniform" Width="22" Height="22"/>
                    </Button>

                    <!-- Повтор -->
                    <Button Grid.Column="4" Style="{StaticResource PlayerControlBtnStyle}"
                            HorizontalAlignment="Center">
                        <Path Data="M1 4v6h6M23 20v-6h-6M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"
                              Stroke="#888880" StrokeThickness="1.8"
                              Fill="Transparent" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                </Grid>

                <!-- Громкость -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <Path Data="M11 5L6 9H2v6h4l5 4V5zM15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14"
                          Stroke="#555552" StrokeThickness="1.5" Fill="Transparent"
                          Stretch="Uniform" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider Style="{StaticResource SliderStyle}" Width="180"
                            Minimum="0" Maximum="100" Value="70" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Grid>

        <!-- ===================== ЦЕНТРАЛЬНАЯ ПАНЕЛЬ ===================== -->
        <Border Grid.Column="1" BorderBrush="#252523" BorderThickness="1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#121211" Offset="0"/>
                    <GradientStop Color="#0A0A09" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel>

                <!-- Заголовок секции -->
                <Border DockPanel.Dock="Top" Padding="28,24,28,20"
                        BorderBrush="#252523" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="В очереди" FontSize="18" FontWeight="Black"
                                   FontFamily="{StaticResource HeaderFont}" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Background="#252523" CornerRadius="8" Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                                <TextBlock Text="Очистить" FontSize="12" Foreground="#888880"
                                           FontFamily="{StaticResource HeaderFont}"/>
                            </Border>
                            <Border Background="{StaticResource AccentColor}" CornerRadius="8"
                                    Padding="12,6" Cursor="Hand">
                                <TextBlock Text="+ Добавить" FontSize="12" FontWeight="Bold"
                                           Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Сейчас играет — выделенный трек -->
                <Border DockPanel.Dock="Top" Padding="16,12" Margin="16,16,16,0"
                        Background="#1E2E1E" CornerRadius="14"
                        BorderBrush="{StaticResource AccentColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E8462A" Offset="0"/>
                                    <GradientStop Color="#FF8C42" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="♪" FontSize="20" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <Border Background="{StaticResource AccentColor}" CornerRadius="4"
                                        Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="ИГРАЕТ" FontSize="9" FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                                <TextBlock Text="Blinding Lights" FontSize="14" FontWeight="Bold"
                                           Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                            </StackPanel>
                            <TextBlock Text="The Weeknd · After Hours" FontSize="12"
                                       Foreground="#888880"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="3:20" FontSize="13"
                                   Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Далее" FontSize="12" FontWeight="Bold"
                           Foreground="#555552" Margin="28,20,0,12"
                           FontFamily="{StaticResource HeaderFont}"/>

                <!-- Список очереди -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                    <StackPanel Margin="16,0,16,24">

                        <!-- Трек в очереди -->
                        <Border Padding="14,10" CornerRadius="12" Margin="0,0,0,6" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1E1C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#11998E" Offset="0"/>
                                            <GradientStop Color="#38EF7D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="♪" FontSize="18" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Anti-Hero" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="Taylor Swift" FontSize="12" Foreground="#555552" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="3:20" FontSize="13"
                                           Foreground="#555552" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Padding="14,10" CornerRadius="12" Margin="0,0,0,6" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1E1C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#667EEA" Offset="0"/>
                                            <GradientStop Color="#764BA2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="♪" FontSize="18" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="As It Was" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="Harry Styles" FontSize="12" Foreground="#555552" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="2:47" FontSize="13"
                                           Foreground="#555552" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Padding="14,10" CornerRadius="12" Margin="0,0,0,6" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1E1C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F093FB" Offset="0"/>
                                            <GradientStop Color="#F5576C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="♪" FontSize="18" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Flowers" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="Miley Cyrus" FontSize="12" Foreground="#555552" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="3:20" FontSize="13"
                                           Foreground="#555552" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Padding="14,10" CornerRadius="12" Margin="0,0,0,6" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1E1C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                        Background="{StaticResource TextPrimary}" Margin="0,0,12,0">
                                    <TextBlock Text="♪" FontSize="18" Foreground="{StaticResource AccentColor}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Levitating" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="Dua Lipa" FontSize="12" Foreground="#555552" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="3:23" FontSize="13"
                                           Foreground="#555552" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Padding="14,10" CornerRadius="12" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1E1C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8462A" Offset="0"/>
                                            <GradientStop Color="#FF8C42" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="♪" FontSize="18" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Heat Waves" FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="Glass Animals" FontSize="12" Foreground="#555552" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="3:59" FontSize="13"
                                           Foreground="#555552" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===================== ПРАВАЯ ПАНЕЛЬ: ТЕКСТ ===================== -->
        <Border Grid.Column="2">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#141413" Offset="0"/>
                    <GradientStop Color="#0A0A09" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>

                <!-- Заголовок -->
                <Border DockPanel.Dock="Top" Padding="24,24,24,20"
                        BorderBrush="#252523" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Текст песни" FontSize="16" FontWeight="Black"
                                   FontFamily="{StaticResource HeaderFont}" Foreground="White"/>
                        <Border Background="#252523" CornerRadius="8" Padding="10,5"
                                HorizontalAlignment="Right" Cursor="Hand">
                            <TextBlock Text="EN / RU" FontSize="11" Foreground="#888880"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Текст с подсветкой текущей строки -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                    <StackPanel Margin="24,20,24,24">

                        <!-- Куплет 1 -->
                        <TextBlock Text="Куплет 1" FontSize="11" FontWeight="Bold"
                                   Foreground="#333330" Margin="0,0,0,12"
                                   FontFamily="{StaticResource HeaderFont}"/>

                        <TextBlock Text="I've been tryna call" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="I've been on my own for long enough" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>

                        <!-- Активная строка — подсвечена -->
                        <Border Background="#1A2E1A" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                            <TextBlock Text="Maybe you can show me how to love, maybe"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource AccentColor}"
                                       FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="I'm going through withdrawals" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="You don't even have to do too much" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="You can turn me on with just a touch, baby" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,24"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>

                        <!-- Припев -->
                        <TextBlock Text="Припев" FontSize="11" FontWeight="Bold"
                                   Foreground="#333330" Margin="0,0,0,12"
                                   FontFamily="{StaticResource HeaderFont}"/>

                        <TextBlock Text="I said, ooh, I'm blinded by the lights" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="No, I can't sleep until I feel your touch" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="I said, ooh, I'm drowning in the night" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="Oh, when I'm like this, you're the one I trust" FontSize="15"
                                   Foreground="#555552" Margin="0,0,0,24"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>

                        <!-- Куплет 2 -->
                        <TextBlock Text="Куплет 2" FontSize="11" FontWeight="Bold"
                                   Foreground="#333330" Margin="0,0,0,12"
                                   FontFamily="{StaticResource HeaderFont}"/>

                        <TextBlock Text="I'm running out of time" FontSize="15"
                                   Foreground="#333330" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="'Cause I can see the sun light up the sky" FontSize="15"
                                   Foreground="#333330" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>
                        <TextBlock Text="So I hit the road in overdrive, baby" FontSize="15"
                                   Foreground="#333330" Margin="0,0,0,8"
                                   FontFamily="{StaticResource BodyFont}" TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
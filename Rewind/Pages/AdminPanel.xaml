<Window x:Class="Rewind.Pages.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rewind"
        mc:Ignorable="d"
        Title="Rewind — Администратор"
        Icon="/Images/rewind_logo.png"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F4F0">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#EBEBE7" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">

                <!-- Логотип -->
                <StackPanel DockPanel.Dock="Top" Margin="24,26,24,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#E8462A" Margin="0,0,10,0">
                            <Image Source="/Images/rewind_logo.png" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="Rewind" VerticalAlignment="Center" FontWeight="Black"
                                   FontSize="16" Foreground="#1A1A18"
                                   FontFamily="{StaticResource HeaderFont}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Бейдж роли -->
                <Border DockPanel.Dock="Top" Margin="16,0,16,20"
                        Background="#1A1A18" CornerRadius="10" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource AccentColor}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Панель администратора" FontSize="12" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"
                                   FontFamily="{StaticResource HeaderFont}"/>
                    </StackPanel>
                </Border>

                <!-- Навигация -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0,12,0">
                    <TextBlock Text="УПРАВЛЕНИЕ" FontSize="10" FontWeight="Bold"
                               Foreground="#BBBBB5" Margin="12,0,0,10"/>

                    <!-- Обзор — активный -->
                    <Button x:Name="SideOverviewBtn" Style="{StaticResource ActiveNavButtonStyle}"
                            Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7"
                                    Background="{DynamicResource AccentColor}" Margin="0,0,10,0">
                                <Path Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                      Fill="White" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Обзор" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Пользователи -->
                    <Button x:Name="SideUsersBtn" Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Пользователи" FontSize="13" Foreground="#888880"/>
                                <Border Background="#E8462A" CornerRadius="8" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="248" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Запросы на регистрацию -->
                    <Button x:Name="SideRequestsBtn" Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,2" >
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Запросы" FontSize="13" Foreground="#888880"/>
                                <Border Background="{StaticResource AccentColor}" CornerRadius="8"
                                        Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="5" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Жалобы -->
                    <Button x:Name="SideComplaintsBtn" Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,2" >
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Жалобы" FontSize="13" Foreground="#888880"/>
                                <Border Background="#FF6B35" CornerRadius="8" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="12" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Треки -->
                    <Button x:Name="SideTracksBtn" Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M12 3v10.55A4 4 0 1 0 14 17V7h4V3z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Треки" FontSize="13" Foreground="#888880" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Аналитика -->
                    <Button x:Name="SideAnalyticsBtn" Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,2" >
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="7" Background="#F0EFEB" Margin="0,0,10,0">
                                <Path Data="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"
                                      Fill="#888880" Stretch="Uniform" Width="14" Height="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Аналитика" FontSize="13" Foreground="#888880" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Аватар внизу -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,20"
                        Background="#F5F4F0" CornerRadius="12" Padding="12,10" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38" CornerRadius="19" Background="#1A1A18">
                            <TextBlock Text="⚙" FontSize="18" Foreground="{StaticResource AccentColor}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Администратор" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A18"/>
                            <TextBlock Text="Полный доступ" FontSize="11" Foreground="#BBBBB5"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="#FFFFFF"
                    BorderBrush="#E0DFD9" BorderThickness="0,0,0,1"
                    Padding="32,20,32,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" Text="Обзор" FontSize="26" FontWeight="Black"
                                   FontFamily="{StaticResource HeaderFont}" Foreground="#1A1A18"/>
                        <TextBlock x:Name="PageSubtitle" Text="Панель управления · Rewind Admin"
                                   FontSize="13" Foreground="#888880" Margin="0,4,0,0"/>
                    </StackPanel>
                    <!-- Поиск -->
                    <Grid Grid.Column="1" Width="260">
                        <TextBox Style="{StaticResource SearchBoxStyle}" Height="40"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                            <Path Data="M10 2a8 8 0 1 0 4.5 14.71l4.9 4.9 1.41-1.42-4.9-4.9A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
                                  Fill="#BBBBB5" Stretch="Uniform" Width="14" Height="14"/>
                            <TextBlock Text="Поиск..." FontSize="13" Foreground="#BBBBB5"
                                       Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Контент панелей -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Background="#F5F4F0">
                <Grid Margin="32,28,32,32">

                    <!-- =========== ОБЗОР =========== -->
                    <StackPanel x:Name="PanelOverview" Visibility="Visible">

                        <!-- Карточки статистики -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="36" Height="36" CornerRadius="10"
                                                Background="#F0EFEB" Margin="0,0,10,0">
                                            <Path Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                                  Fill="#888880" Stretch="Uniform" Width="16" Height="16"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Пользователей" FontSize="13"
                                                   Foreground="#888880" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="248" FontSize="32" FontWeight="Black"
                                               Foreground="#1A1A18" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="↑ +12 за неделю" FontSize="12"
                                               Foreground="{StaticResource AccentColor}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="36" Height="36" CornerRadius="10"
                                                Background="#F0EFEB" Margin="0,0,10,0">
                                            <Path Data="M12 3v10.55A4 4 0 1 0 14 17V7h4V3z"
                                                  Fill="#888880" Stretch="Uniform" Width="16" Height="16"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Треков в базе" FontSize="13"
                                                   Foreground="#888880" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="1 842" FontSize="32" FontWeight="Black"
                                               Foreground="#1A1A18" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="↑ +34 за неделю" FontSize="12"
                                               Foreground="{StaticResource AccentColor}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="36" Height="36" CornerRadius="10"
                                                Background="#FFF0ED" Margin="0,0,10,0">
                                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                                  Fill="#FF6B35" Stretch="Uniform" Width="16" Height="16"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Жалоб" FontSize="13"
                                                   Foreground="#888880" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="12" FontSize="32" FontWeight="Black"
                                               Foreground="#FF6B35" FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="Требуют внимания" FontSize="12"
                                               Foreground="#FF6B35" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="6" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="36" Height="36" CornerRadius="10"
                                                Background="#F0FFF4" Margin="0,0,10,0">
                                            <Path Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                                  Fill="{StaticResource AccentColor}" Stretch="Uniform" Width="16" Height="16"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Запросов" FontSize="13"
                                                   Foreground="#888880" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="5" FontSize="32" FontWeight="Black"
                                               Foreground="{StaticResource AccentColor}"
                                               FontFamily="{StaticResource HeaderFont}"/>
                                    <TextBlock Text="На регистрацию" FontSize="12"
                                               Foreground="{StaticResource AccentColor}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- График прослушиваний (имитация через Border-столбцы) -->
                        <Border Background="#FFFFFF" CornerRadius="16" BorderBrush="#E0DFD9"
                                BorderThickness="1" Padding="24,20" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Прослушивания за 7 дней" FontSize="16" FontWeight="Black"
                                               Foreground="#1A1A18" FontFamily="{StaticResource HeaderFont}"/>
                                    <Border Background="#F5F4F0" CornerRadius="8" Padding="10,5"
                                            HorizontalAlignment="Right" Cursor="Hand">
                                        <TextBlock Text="Последние 7 дней ↓" FontSize="12"
                                                   Foreground="#888880"/>
                                    </Border>
                                </Grid>
                                <!-- Псевдо-график: столбики -->
                                <Grid Height="140">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Пн -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                                        <Border Height="85" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Пн" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <!-- Вт -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <Border Height="110" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Вт" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <!-- Ср -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                        <Border Height="60" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Ср" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <!-- Чт -->
                                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                        <Border Height="130" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Чт" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <!-- Пт -->
                                    <StackPanel Grid.Column="8" VerticalAlignment="Bottom">
                                        <Border Height="95" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Пт" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <!-- Сб -->
                                    <StackPanel Grid.Column="10" VerticalAlignment="Bottom">
                                        <Border Height="120" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Сб" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <!-- Вс -->
                                    <StackPanel Grid.Column="12" VerticalAlignment="Bottom">
                                        <Border Height="75" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2AE876" Offset="0"/>
                                                    <GradientStop Color="#23C13A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="Вс" FontSize="11" Foreground="#888880"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- График регистраций -->
                        <Border Background="#FFFFFF" CornerRadius="16" BorderBrush="#E0DFD9"
                                BorderThickness="1" Padding="24,20">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Регистрации за 7 дней" FontSize="16" FontWeight="Black"
                                               Foreground="#1A1A18" FontFamily="{StaticResource HeaderFont}"/>
                                </Grid>
                                <Grid Height="100">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                                        <Border Height="40" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Пн" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <Border Height="65" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Вт" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                        <Border Height="30" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Ср" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                        <Border Height="80" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Чт" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="8" VerticalAlignment="Bottom">
                                        <Border Height="55" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Пт" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="10" VerticalAlignment="Bottom">
                                        <Border Height="70" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Сб" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="12" VerticalAlignment="Bottom">
                                        <Border Height="45" CornerRadius="6,6,0,0" Background="#1A1A18"/>
                                        <TextBlock Text="Вс" FontSize="11" Foreground="#888880" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- =========== ПОЛЬЗОВАТЕЛИ =========== -->

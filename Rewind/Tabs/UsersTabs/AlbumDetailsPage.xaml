<UserControl x:Class="Rewind.Tabs.UsersTabs.AlbumDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             Height="auto" Width="auto">
    <Grid Background="{DynamicResource BgMain}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,120">
                <Border Background="{DynamicResource GreenGradientStyle}" CornerRadius="20" Padding="24" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="AlbumCover" Width="120" Height="120" CornerRadius="16" ClipToBounds="True"
                                Background="{DynamicResource GreenGradientStyle}" Margin="0,0,22,0">
                            <Grid>
                                <Image x:Name="AlbumCoverPlaceholder" Source="{help:Icon music_note.png}"
                                       Width="56" Height="56"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:Name="AlbumCoverImage" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="AlbumTitleText" FontSize="28" FontWeight="Black" Foreground="White" FontFamily="{StaticResource HeaderFont}"/>
                            <TextBlock x:Name="AlbumArtistText" FontSize="14" Foreground="#DDFFFFFF" Margin="0,6,0,0"/>
                            <TextBlock x:Name="AlbumStatsText" FontSize="13" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                            <Border Background="#1A1A18" CornerRadius="16" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Back_Click">
                                <StackPanel Orientation="Horizontal" Margin="14,8">
                                    <Image Source="{help:Icon nav_back.png}" Width="12" Height="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Назад" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SaveAlbumBtn" Background="#1A1A18" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="SaveAlbum_Click">
                                <TextBlock x:Name="SaveAlbumText" Text="♥ Сохранить" Margin="14,8" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Треки альбома" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimary}"/>
                <StackPanel x:Name="TracksContainer"/>
                <TextBlock x:Name="EmptyText" Text="В этом альбоме пока нет треков" Visibility="Collapsed" Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

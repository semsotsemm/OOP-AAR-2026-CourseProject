<UserControl x:Class="Rewind.Tabs.UsersTabs.MainPage"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:help="clr-namespace:Rewind.Helpers"
              xmlns:local="clr-namespace:Rewind.Contols"
              mc:Ignorable="d"
              Height="auto" Width="auto">
    <Grid>
        <Grid Grid.Column="1">

            <!-- ===== СТРАНИЦА: ГЛАВНАЯ ===== -->
            <ScrollViewer x:Name="PageHome" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BgMain}" Visibility="Visible">
                <StackPanel Margin="32,28,32,120">

                    <!-- Заголовок -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="GreetingText" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBlock Text="Главная" FontSize="28" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <!-- Колокольчик — открывает уведомления -->
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Border Width="42" Height="42" Background="{DynamicResource BgCardHover}"
                                    CornerRadius="21" Cursor="Hand" MouseLeftButtonDown="Bell_Click">
                                <Rectangle Width="20" Height="20"
                                           Fill="{StaticResource AccentColor}"
                                           VerticalAlignment="Center" Cursor="Hand">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{help:Icon bell.png}" Stretch="Uniform"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                            </Border>
                            <!-- Бейдж счётчика непрочитанных уведомлений -->
                            <Border x:Name="NotifBadge" Width="18" Height="18" CornerRadius="9"
                                    Background="#E53935"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,0,-2,-2"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="NotifBadgeText" Text="0" FontSize="8"
                                           Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Трек дня -->
                    <Border Background="{StaticResource GreenGradientStyle}" CornerRadius="20"
                            Margin="0,0,0,32" Height="186" Cursor="Hand">
                        <Grid Margin="28,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <Border Background="{StaticResource AccentColor}" CornerRadius="6"
                                        Padding="10,5" HorizontalAlignment="Left">

                                    <StackPanel Orientation="Horizontal">

                                        <Rectangle Width="20"
                                                   Height="20"
                                                   Fill="{DynamicResource BgCard}"
                                                   VerticalAlignment="Center"
                                                   Cursor="Hand"
                                                   Margin="0,0,6,0">
                                            <!-- Отступ справа, чтобы не прилипало к тексту -->
                                            <Rectangle.OpacityMask>
                                                <ImageBrush ImageSource="{help:Icon fire_icon.png}"
                                                            Stretch="Uniform"/>
                                            </Rectangle.OpacityMask>
                                        </Rectangle>

                                        <TextBlock Text="Трек дня"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   FontFamily="{StaticResource HeaderFont}"
                                                   Foreground="{DynamicResource BgCard}"
                                                   VerticalAlignment="Center"/>

                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="FeaturedTrackTitle"
                                           Text="Загрузка..." FontSize="26" FontWeight="Bold"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="White" Margin="0,5,0,0"/>
                                <TextBlock x:Name="FeaturedTrackArtist"
                                           Text="" FontSize="14"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="White" Margin="0,6,0,16"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource BgCard}" CornerRadius="20" Padding="18,8" Cursor="Hand"
                                            MouseLeftButtonDown="FeaturedPlay_Click">
                                        <StackPanel Orientation="Horizontal">

                                            <Rectangle Grid.Column="2"
                                                       Width="12"
                                                       Height="12"
                                                       Fill="{StaticResource AccentColor}"
                                                       VerticalAlignment="Center"
                                                       Cursor="Hand">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="{help:Icon player_play.png}"
                                                                Stretch="Uniform"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>

                                            <TextBlock Text=" Слушать" FontSize="13" FontWeight="SemiBold"
                                                       FontFamily="{StaticResource HeaderFont}"
                                                       Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Grid Grid.Column="1">
                                <Border Width="120" Height="120" CornerRadius="16" VerticalAlignment="Center" ClipToBounds="True">
                                    <Image x:Name="FeaturedTrackCover"
                                           Source="{help:Icon music_note.png}"
                                           Width="120" Height="120"
                                           Stretch="UniformToFill"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Рекомендации -->
                    <StackPanel Margin="0,0,0,28">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Рекомендации для вас" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" FontFamily="{StaticResource HeaderFont}"/>
                            <TextBlock x:Name="ShowAllTracksBtn" Text="Все →" FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       FontFamily="{StaticResource HeaderFont}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                                       MouseLeftButtonDown="ShowAllTracksBtn_Click"/>
                        </Grid>
                        <StackPanel x:Name="MusicContainer" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Популярные плейлисты -->
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Популярные плейлисты" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" FontFamily="{StaticResource HeaderFont}"/>
                        </Grid>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden" Height="210">
                            <StackPanel x:Name="PopularPlaylistsContainer" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="NotificationsPanel" Visibility="Collapsed"
                            Background="{DynamicResource BgCard}"
                            CornerRadius="20"
                            BorderBrush="#E8E7E1"
                            BorderThickness="1"
                            Margin="0,74,50,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="300">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="6" Direction="270"
                                                Color="#1A1A18" Opacity="0.13"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Шапка -->
                    <Border Background="{DynamicResource BgMain}" CornerRadius="20,20,0,0">
                        <Grid Margin="20,16,20,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="14"
                                               Height="14"
                                               Margin="0,0,6,0"
                                               Fill="{StaticResource AccentColor}"
                                               Cursor="Hand">
                                        <Rectangle.OpacityMask>
                                            <ImageBrush ImageSource="{help:Icon bell.png}" Stretch="Uniform"/>
                                        </Rectangle.OpacityMask>
                                    </Rectangle>
                                    <TextBlock Text="Центр уведомлений" FontSize="14" FontWeight="Bold"
                                                       FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                                <TextBlock Text="Настройки и интерфейс" FontSize="11"
                                                   FontFamily="{StaticResource HeaderFont}"
                                                   Foreground="{StaticResource AccentColor}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Тело -->
                    <StackPanel Margin="20,16,20,20">

                        <!-- РАЗДЕЛ: Уведомления -->
                        <TextBlock Text="УВЕДОМЛЕНИЯ" FontSize="10" FontWeight="Bold"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12"/>

                        <!-- Новые треки -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Новые треки от авторов" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Получать оповещения о релизах" FontSize="11"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <CheckBox x:Name="NotifNewTracks" Grid.Column="1"
                          IsChecked="True" VerticalAlignment="Center"
                          Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>

                        <!-- Push -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Push-уведомления" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="На устройство в реальном времени" FontSize="11"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <CheckBox x:Name="NotifPush" Grid.Column="1"
                          IsChecked="True" VerticalAlignment="Center"
                          Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>

                        <!-- Разделитель -->
                        <Border Height="1" Background="{DynamicResource TextMuted}" Margin="0,16,0,16"/>

                        <!-- РАЗДЕЛ: Динамический остров -->
                        <TextBlock Text="ДИНАМИЧЕСКИЙ ОСТРОВ" FontSize="10" FontWeight="Bold"
                       FontFamily="{StaticResource HeaderFont}"
                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12"/>

                        <!-- Включить/выключить -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Показывать остров" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Мини-плеер поверх экрана" FontSize="11"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <CheckBox x:Name="IslandEnabledToggle" Grid.Column="1"
                                      IsChecked="True" VerticalAlignment="Center"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      Checked="IslandSettings_Changed"
                                      Unchecked="IslandSettings_Changed"/>
                        </Grid>

                        <!-- Прозрачность -->
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Непрозрачность" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="OpacityLabel" Text="100%" FontSize="11"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="IslandOpacitySlider"
                        Minimum="0.25" Maximum="1.0" Value="1.0"
                        Style="{StaticResource GreenSliderStyle}"
                        ValueChanged="IslandSettings_Changed"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

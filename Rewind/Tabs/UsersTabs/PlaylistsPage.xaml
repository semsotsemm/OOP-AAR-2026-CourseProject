<UserControl x:Class="Rewind.Tabs.UsersTabs.PlaylistsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:local="clr-namespace:Rewind"
             mc:Ignorable="d"
             Height="auto" Width="auto">

    <Grid Background="{DynamicResource BgMain}">

        <ScrollViewer x:Name="PagePlaylists"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,120">

                <!-- ===== ЗАГОЛОВОК ===== -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ваша музыка" FontSize="13"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                        <TextBlock Text="Плейлисты" FontSize="28" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Кнопка создать плейлист -->
                    <Border Grid.Column="1" CornerRadius="20" Cursor="Hand"
                            VerticalAlignment="Center"
                            MouseLeftButtonDown="CreatePlaylist_Click">
                        <Border.Background>
                            <SolidColorBrush Color="#2AE876"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" Margin="18,10">
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Новый плейлист" FontSize="13" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== СТРОКА ПОИСКА ===== -->
                <Border Background="{DynamicResource BgSidebar}" CornerRadius="14"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5"
                        Margin="0,0,0,28">
                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{help:Icon nav_search.png}" Width="15" Height="15" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Height="46" FontSize="14"
                                 FontFamily="{StaticResource BodyFont}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Tag="Поиск плейлистов..."
                                 TextChanged="SearchBox_TextChanged"
                                 Style="{StaticResource SearchBoxStyle}"/>
                    </Grid>
                </Border>

                <!-- ===== ЗАКРЕПЛЁННЫЕ ПЛЕЙЛИСТЫ ===== -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Закреплённые" FontSize="16" FontWeight="Bold"
                               FontFamily="{StaticResource HeaderFont}"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Любимые треки -->
                        <Border Grid.Column="0" CornerRadius="20" Height="110" Cursor="Hand"
                                MouseLeftButtonDown="FavoritesPlaylist_Click">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2AE876" Offset="0"/>
                                    <GradientStop Color="#004D40" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid Margin="22,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{help:Icon like_filled.png}" Width="16" Height="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Любимые треки" FontSize="16" FontWeight="Bold"
                                                   FontFamily="{StaticResource HeaderFont}" Foreground="White"/>
                                    </StackPanel>
                                    <TextBlock x:Name="FavoritesCountText" Text="0 треков" FontSize="12"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="#FFFFFF99" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Width="54" Height="54" CornerRadius="27"
                                        Background="#FFFFFF22" VerticalAlignment="Center">
                                    <Image Source="{help:Icon player_play.png}" Width="18" Height="18"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Недавно прослушанные -->
                        <Border Grid.Column="2" CornerRadius="20" Height="110" Cursor="Hand">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#667EEA" Offset="0"/>
                                    <GradientStop Color="#764BA2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid Margin="22,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{help:Icon clock.png}" Width="16" Height="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Недавно слушали" FontSize="16" FontWeight="Bold"
                                                   FontFamily="{StaticResource HeaderFont}" Foreground="White"/>
                                    </StackPanel>
                                    <TextBlock Text="История воспроизведения" FontSize="12"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="#FFFFFF99" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Width="54" Height="54" CornerRadius="27"
                                        Background="#FFFFFF22" VerticalAlignment="Center">
                                    <Image Source="{help:Icon player_play.png}" Width="18" Height="18"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ===== МОИ ПЛЕЙЛИСТЫ ===== -->
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Мои плейлисты" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontFamily="{StaticResource HeaderFont}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <!-- Переключатель вид: сетка / список -->
                            <Border x:Name="ViewGrid" Width="34" Height="34" CornerRadius="10"
                                    Cursor="Hand" Margin="0,0,6,0"
                                    MouseLeftButtonDown="SwitchToGrid_Click">
                                <Border.Background>
                                    <SolidColorBrush x:Name="GridViewBg" Color="#2AE876"/>
                                </Border.Background>
                                <Image Source="{help:Icon view_grid.png}" Width="16" Height="16"/>
                            </Border>
                            <Border x:Name="ViewList" Width="34" Height="34" CornerRadius="10"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="SwitchToList_Click">
                                <Border.Background>
                                    <SolidColorBrush x:Name="ListViewBg" Color="#F0EFEB"/>
                                </Border.Background>
                                <Image Source="{help:Icon view_list.png}" Width="16" Height="16"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Фильтры -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border x:Name="FilterAll" CornerRadius="20" Padding="16,8" Cursor="Hand"
                                Margin="0,0,8,0" MouseLeftButtonDown="FilterAll_Click">
                            <Border.Background>
                                <SolidColorBrush Color="#1A1A18"/>
                            </Border.Background>
                            <TextBlock Text="Все" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}" Foreground="White"/>
                        </Border>
                        <Border x:Name="FilterOwn" CornerRadius="20" Padding="16,8" Cursor="Hand"
                                Margin="0,0,8,0" MouseLeftButtonDown="FilterOwn_Click">
                            <Border.Background>
                                <SolidColorBrush Color="#F0EFEB"/>
                            </Border.Background>
                            <TextBlock Text="Мои" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                        <Border x:Name="FilterSaved" CornerRadius="20" Padding="16,8" Cursor="Hand"
                                MouseLeftButtonDown="FilterSaved_Click">
                            <Border.Background>
                                <SolidColorBrush Color="#F0EFEB"/>
                            </Border.Background>
                            <TextBlock Text="Сохранённые" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                    </StackPanel>

                    <!-- Сетка плейлистов (по умолчанию) -->
                    <WrapPanel x:Name="PlaylistsGridPanel" Orientation="Horizontal"/>

                    <!-- Список плейлистов (альтернативный вид) -->
                    <StackPanel x:Name="PlaylistsListPanel" Visibility="Collapsed"/>

                    <!-- Пустое состояние -->
                    <Border x:Name="EmptyState" Visibility="Collapsed"
                            CornerRadius="20" Background="{DynamicResource BgSidebar}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5"
                            Padding="40" Margin="0,10,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Source="{help:Icon music_note.png}" Width="48" Height="48" Margin="0,0,0,16"/>
                            <TextBlock Text="Нет плейлистов" FontSize="18" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Создайте свой первый плейлист или сохраните чужой"
                                       FontSize="13" FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,0,0,24"/>
                            <Border CornerRadius="20" Cursor="Hand" HorizontalAlignment="Center"
                                    MouseLeftButtonDown="CreatePlaylist_Click">
                                <Border.Background>
                                    <SolidColorBrush Color="#2AE876"/>
                                </Border.Background>
                                <TextBlock Text="+ Создать плейлист" FontSize="13" FontWeight="Bold"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="White" Margin="20,10"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== МОДАЛЬНОЕ ОКНО: СОЗДАНИЕ ПЛЕЙЛИСТА ===== -->
        <Grid x:Name="CreatePlaylistModal" Visibility="Collapsed" Panel.ZIndex="100">
            <Rectangle Fill="#1A1A18" Opacity="0.5"/>
            <Border Background="{DynamicResource BgSidebar}" CornerRadius="24"
                    Width="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="36,32">
                <StackPanel>
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="Новый плейлист" FontSize="22" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Border Width="32" Height="32" CornerRadius="16" Background="#F0EFEB"
                                HorizontalAlignment="Right" Cursor="Hand"
                                MouseLeftButtonDown="CloseModal_Click">
                            <TextBlock Text="✕" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Обложка -->
                    <Border x:Name="CoverPicker" Width="100" Height="100" CornerRadius="16"
                            HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,0,24"
                            MouseLeftButtonDown="PickCover_Click">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2AE876" Offset="0"/>
                                <GradientStop Color="#004D40" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Source="{help:Icon music_note.png}" Width="32" Height="32"/>
                            <TextBlock Text="Изменить" FontSize="11"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="#FFFFFF99"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="НАЗВАНИЕ" Style="{StaticResource FieldLabel}" Margin="0,0,0,7"/>
                    <TextBox x:Name="PlaylistNameBox"
                             Style="{StaticResource InputField}"
                             Tag="Название плейлиста"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="ОПИСАНИЕ" Style="{StaticResource FieldLabel}" Margin="0,0,0,7"/>
                    <Border Background="{DynamicResource BgSidebar}"
                            BorderBrush="#E0DFD9" BorderThickness="1.5" CornerRadius="12"
                            Margin="0,0,0,24">
                        <TextBox x:Name="PlaylistDescBox"
                                 Height="80" FontSize="14"
                                 FontFamily="{StaticResource BodyFont}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="16,12" TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <!-- Приватность -->
                    <Grid Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock Text="Приватный плейлист" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Только вы сможете его видеть" FontSize="12"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="PrivateToggle"
                                  Style="{StaticResource ModernToggleStyle}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Style="{StaticResource BtnRed}"
                            Content="Создать плейлист"
                            FontFamily="{StaticResource HeaderFont}"
                            Click="ConfirmCreatePlaylist_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Tabs.UsersTabs.FavoritesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:local="clr-namespace:Rewind.Contols"
             mc:Ignorable="d"
             Height="auto" Width="auto">

    <Grid Background="{DynamicResource BgMain}">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,120">

                <!-- ===== ЗАГОЛОВОК ===== -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ваша музыка" FontSize="13"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{help:Icon like_filled.png}" Width="26" Height="26" Margin="0,0,10,0"/>
                            <TextBlock Text="Любимые треки" FontSize="28" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка «Слушать всё» -->
                    <Border Grid.Column="1" CornerRadius="20" Cursor="Hand"
                            VerticalAlignment="Center"
                            MouseLeftButtonDown="PlayAll_Click">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A18"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" Margin="18,10">
                            <Image Source="{help:Icon player_play.png}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Слушать всё" FontSize="13" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== БАННЕР-СТАТИСТИКА ===== -->
                <Border CornerRadius="20" Margin="0,0,0,28" Height="120">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2AE876" Offset="0"/>
                            <GradientStop Color="#004D40" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Статистика 1 -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatTracksCount" Text="128"
                                       FontSize="32" FontWeight="Black"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                            <TextBlock Text="треков" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="#FFFFFF99"/>
                        </StackPanel>

                        <!-- Разделитель -->
                        <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right"
                                   Fill="#FFFFFF33" Margin="0,16"/>

                        <!-- Статистика 2 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="StatArtistsCount" Text="34"
                                       FontSize="32" FontWeight="Black"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                            <TextBlock Text="исполнителей" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="#FFFFFF99"/>
                        </StackPanel>

                        <!-- Разделитель -->
                        <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Right"
                                   Fill="#FFFFFF33" Margin="0,16"/>

                        <!-- Статистика 3 -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="StatDuration" Text="8ч 42м"
                                       FontSize="32" FontWeight="Black"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                            <TextBlock Text="общее время" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="#FFFFFF99"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== ПОИСК + СОРТИРОВКА ===== -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Поиск -->
                    <Border Grid.Column="0" Background="{DynamicResource BgSidebar}"
                            CornerRadius="14" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1.5">
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{help:Icon nav_search.png}" Width="15" Height="15" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" x:Name="SearchBox"
                                     Height="46" FontSize="14"
                                     FontFamily="{StaticResource BodyFont}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Tag="Поиск в любимых..."
                                     TextChanged="SearchBox_TextChanged"
                                     Style="{StaticResource SearchBoxStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Сортировка -->
                    <Border Grid.Column="2" Background="{DynamicResource BgSidebar}"
                            CornerRadius="14" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1.5" Cursor="Hand"
                            MouseLeftButtonDown="ToggleSort_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <Image x:Name="SortIcon" Source="{help:Icon sort.png}" Width="15" Height="15" Margin="0,0,8,0"/>
                            <TextBlock x:Name="SortLabel" Text="Недавние"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Height="46"
                                       LineHeight="46" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== ФИЛЬТРЫ ПО ЖАНРУ ===== -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Hidden"
                              Margin="0,0,0,24" Height="36">
                    <StackPanel x:Name="GenreFilters" Orientation="Horizontal"/>
                </ScrollViewer>

                <!-- ===== ШАПКА ТАБЛИЦЫ ===== -->
                <Border Background="{DynamicResource BgSidebar}"
                        CornerRadius="12" Padding="14,10"
                        Margin="0,0,0,6"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="ТРЕК" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="АЛЬБОМ" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}"/>
                        <TextBlock Grid.Column="3" Text="ДАТА" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}"/>
                        <Image Grid.Column="4" Source="{help:Icon clock.png}" Width="11" Height="11"/>
                    </Grid>
                </Border>

                <!-- ===== СПИСОК ТРЕКОВ ===== -->
                <StackPanel x:Name="TracksContainer"/>

                <!-- Пустое состояние -->
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        CornerRadius="20" Background="{DynamicResource BgSidebar}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5"
                        Padding="40" Margin="0,10,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{help:Icon like_outline.png}" Width="52" Height="52" Margin="0,0,0,16"/>
                        <TextBlock Text="Здесь пока пусто" FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Лайкайте треки — они появятся здесь"
                                   FontSize="13" FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

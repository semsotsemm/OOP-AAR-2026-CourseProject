<UserControl x:Class="Rewind.Tabs.UsersTabs.FavoritesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:local="clr-namespace:Rewind.Contols"
             mc:Ignorable="d"
             Height="auto" Width="auto">

    <Grid Background="{DynamicResource BgMain}">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,120">

                <!-- ===== ЗАГОЛОВОК ===== -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ваша музыка" FontSize="13"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">

                            <Rectangle Width="26"
                                       Height="26"
                                       Fill="{DynamicResource AccentColor}"
                                       VerticalAlignment="Center"
                                       Cursor="Hand"
                                       Margin="0,0,10,0">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{help:Icon like_filled.png}" Stretch="Uniform"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>

                            <TextBlock Text="Любимые треки" FontSize="28" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопка «Слушать всё» -->
                    <Border Grid.Column="1" CornerRadius="20" Cursor="Hand"
                            VerticalAlignment="Center"
                            MouseLeftButtonDown="PlayAll_Click">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A18"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" Margin="18,10">
                            <Image Source="{help:Icon player_play.png}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Слушать всё" FontSize="13" FontWeight="Bold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== БАННЕР-СТАТИСТИКА ===== -->
                <Border CornerRadius="20" Margin="0,0,0,28" Height="120" Background="{StaticResource GreenGradientStyle}" >
                    <Grid Margin="28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Статистика 1 -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatTracksCount" Text="128"
                                       FontSize="32" FontWeight="Black"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground = "White"/>
                            <TextBlock Text="треков" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                        </StackPanel>

                        <!-- Разделитель -->
                        <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right"
                                   Fill="White" Margin="0,16"/>

                        <!-- Статистика 2 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="StatArtistsCount" Text="34"
                                       FontSize="32" FontWeight="Black"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                            <TextBlock Text="исполнителей" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                        </StackPanel>

                        <!-- Разделитель -->
                        <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Right"
                                   Fill="White" Margin="0,16"/>

                        <!-- Статистика 3 -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="StatDuration" Text="8ч 42м"
                                       FontSize="32" FontWeight="Black"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                            <TextBlock Text="общее время" FontSize="13"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== ПОИСК + СОРТИРОВКА ===== -->
                <Grid Margin="0,0,0,20">
                    <!-- Поиск -->
                    <Border Grid.Column="0" Background="{DynamicResource BgSidebar}"
                            CornerRadius="14" BorderBrush="{DynamicResource BorderColor}">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" 
                                       Width="18"
                                       Height="18"
                                       Fill="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Cursor="Hand">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{help:Icon nav_search.png}" Stretch="Uniform"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBox Grid.Column="1" x:Name="SearchBox"
                                     FontSize="14"
                                     FontFamily="{StaticResource BodyFont}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Tag="Поиск в любимых..."
                                     TextChanged="SearchBox_TextChanged"
                                     Style="{StaticResource SearchBoxStyle}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===== ФИЛЬТРЫ ПО ЖАНРАМ ===== -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="GenreDropdownBtn"
                            Grid.Column="0"
                            Background="{DynamicResource BgSidebar}"
                            CornerRadius="16"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1.5"
                            Padding="16,12"
                            Cursor="Hand"
                            MouseLeftButtonDown="ToggleGenreDropdown_Click">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Жанры" FontSize="13" FontWeight="Bold"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="GenreDropdownLabel"
                                               Text="Все жанры"
                                               FontSize="11"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="⌄" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColor}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="GenreDropdownPopup"
                           PlacementTarget="{Binding ElementName=GenreDropdownBtn}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Width="{Binding ActualWidth, ElementName=GenreDropdownBtn}"
                                Background="{DynamicResource BgCard}"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1.5"
                                Padding="16"
                                Margin="0,8,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="5" Opacity="0.18"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Выберите один или несколько жанров" FontSize="13" FontWeight="Bold"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Сброс" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentColor}"
                                               HorizontalAlignment="Right" Cursor="Hand"
                                               MouseLeftButtonDown="ClearGenreFilters_Click"/>
                                </Grid>
                                <WrapPanel x:Name="GenreFilters"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Сортировка -->
                    <Border Grid.Column="2" Background="{DynamicResource BgSidebar}"
                            CornerRadius="14" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1.5" Cursor="Hand"
                            MouseLeftButtonDown="ToggleSort_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <Rectangle x:Name="SortIcon"
                                       Width="18"
                                       Height="18"
                                       Margin="0,0,8,0"
                                       Fill="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Cursor="Hand">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{help:Icon sort.png}" Stretch="Uniform"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock x:Name="SortLabel" Text="Недавние"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <!-- ===== ШАПКА ТАБЛИЦЫ ===== -->
                <Border Background="{DynamicResource BgSidebar}"
                        CornerRadius="12" Padding="14,10"
                        Margin="0,0,0,6"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="95"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="ТРЕК" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="ДЛИТЕЛЬНОСТЬ" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontFamily="{StaticResource HeaderFont}"/>
                    </Grid>
                </Border>

                <!-- ===== СПИСОК ТРЕКОВ ===== -->
                <StackPanel x:Name="TracksContainer"/>

                <!-- Пустое состояние -->
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        CornerRadius="20" Background="{DynamicResource BgSidebar}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5"
                        Padding="40" Margin="0,10,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{help:Icon like_outline.png}" Width="52" Height="52" Margin="0,0,0,16"/>
                        <TextBlock Text="Здесь пока пусто" FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Лайкайте треки — они появятся здесь"
                                   FontSize="13" FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

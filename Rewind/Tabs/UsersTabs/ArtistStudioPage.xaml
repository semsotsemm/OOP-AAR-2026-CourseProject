<UserControl x:Class="Rewind.Tabs.UsersTabs.ArtistStudioPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:help="clr-namespace:Rewind.Helpers"
             mc:Ignorable="d"
             Height="auto" Width="auto">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{StaticResource BgMain}">
        <Grid Margin="32,28,32,80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== PAGE HEADER ===== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Студия исполнителя"
                           FontSize="28" FontWeight="Bold"
                           FontFamily="{StaticResource HeaderFont}"
                           Foreground="#1A1A18"/>
                <TextBlock Text="Управляйте треками и смотрите аналитику"
                           FontSize="13" Foreground="#888880" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ===== TWO-COLUMN LAYOUT ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- ========== LEFT COLUMN ========== -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab switcher -->
                    <Border Grid.Row="0" Background="#F5F4F0" CornerRadius="12"
                            Padding="4" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TabUpload"
                                    Content="Загрузить трек"
                                    Click="TabUpload_Click"
                                    Style="{StaticResource ProfileTabActive}"
                                    Width="140"/>
                            <Button x:Name="TabMyTracks"
                                    Content="Мои треки"
                                    Click="TabMyTracks_Click"
                                    Style="{StaticResource ProfileTab}"
                                    Width="120"/>
                        </StackPanel>
                    </Border>

                    <!-- ======= PANEL: Upload Track ======= -->
                    <Border x:Name="PanelUpload" Grid.Row="1"
                            Background="White" CornerRadius="16" Padding="24"
                            BorderBrush="#E0DFD9" BorderThickness="1"
                            Visibility="Visible">
                        <StackPanel>

                            <!-- Panel header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Image Source="{help:Icon upload.png}"
                                       Width="18" Height="18"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Загрузить новый трек"
                                           FontWeight="Black" FontSize="18"
                                           FontFamily="{StaticResource HeaderFont}"
                                           Foreground="#1A1A18"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Track name -->
                            <TextBlock Text="Название трека"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#888880" Margin="0,0,0,5"/>
                            <TextBox x:Name="NewTrackName"
                                     Margin="0,0,0,18" Padding="10,8"
                                     Tag="Введите название..."/>

                            <!-- Cover + Audio row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Cover picker (120×120) -->
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Text="Обложка"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#888880" Margin="0,0,0,5"/>
                                    <Border Width="120" Height="120"
                                            Background="#F5F4F0" CornerRadius="8"
                                            BorderBrush="#E0DFD9" BorderThickness="1"
                                            Cursor="Hand" ClipToBounds="True"
                                            MouseDown="SelectCover_Click">
                                        <Grid>
                                            <Image x:Name="NewTrackCoverPreview"
                                                   Stretch="UniformToFill"/>
                                            <StackPanel x:Name="CoverPlaceholder"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <Image Source="{help:Icon image_add.png}"
                                                       Width="24" Height="24"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,5"/>
                                                <TextBlock Text="Выбрать"
                                                           FontSize="10" Foreground="#888880"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Audio file + Genre -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock Text="Аудиофайл"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#888880" Margin="0,0,0,5"/>
                                    <Button Click="SelectAudio_Click" Height="40"
                                            Background="#F5F4F0" BorderBrush="#E0DFD9"
                                            HorizontalContentAlignment="Left" Padding="15,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{help:Icon music_note.png}"
                                                   Width="14" Height="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                            <TextBlock Text="Выбрать MP3/WAV"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock x:Name="AudioFileName"
                                               Text="Файл не выбран"
                                               FontSize="11" Foreground="#888880"
                                               Margin="4,5,0,0"/>

                                    <TextBlock Text="Жанр"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#888880" Margin="0,15,0,5"/>
                                    <ComboBox x:Name="GenreSelector" Height="35">
                                        <ComboBoxItem Content="Pop" IsSelected="True"/>
                                        <ComboBoxItem Content="Rock"/>
                                        <ComboBoxItem Content="Hip-Hop"/>
                                        <ComboBoxItem Content="Electronic"/>
                                        <ComboBoxItem Content="R&amp;B"/>
                                        <ComboBoxItem Content="Jazz"/>
                                        <ComboBoxItem Content="Classical"/>
                                        <ComboBoxItem Content="Metal"/>
                                        <ComboBoxItem Content="Folk"/>
                                        <ComboBoxItem Content="Indie"/>
                                        <ComboBoxItem Content="Alternative"/>
                                        <ComboBoxItem Content="Dance"/>
                                        <ComboBoxItem Content="Reggae"/>
                                        <ComboBoxItem Content="Latin"/>
                                        <ComboBoxItem Content="Other"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Separator Margin="0,20" Background="#F5F4F0"/>

                            <Button Content="📤  Отправить на проверку"
                                    Click="UploadTrack_Click"
                                    Height="45"
                                    Background="{DynamicResource AccentColor}"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- ======= PANEL: My Tracks ======= -->
                    <Border x:Name="PanelMyTracks" Grid.Row="1"
                            Background="White" CornerRadius="16" Padding="24"
                            BorderBrush="#E0DFD9" BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel>

                            <!-- Header + refresh -->
                            <Grid Margin="0,0,0,16">
                                <TextBlock x:Name="MyTracksHeader"
                                           Text="Мои треки"
                                           FontSize="16" FontWeight="Black"
                                           Foreground="#1A1A18"
                                           FontFamily="{StaticResource HeaderFont}"
                                           VerticalAlignment="Center"/>
                                <Border Background="#F5F4F0" CornerRadius="8"
                                        Padding="12,6" HorizontalAlignment="Right"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="RefreshTracks_Click">
                                    <TextBlock Text="↻ Обновить"
                                               FontSize="12" Foreground="#888880"/>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="MyTracksContainer"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== RIGHT COLUMN (~320 px) ========== -->
                <!-- Both panels live in the same cell so they can overlap -->
                <Grid Grid.Column="2">

                    <!-- Default panel: tips + stats (visible by default) -->
                    <StackPanel x:Name="PanelRightDefault" Visibility="Visible">

                        <!-- Tips card (green gradient) -->
                        <Border Background="{StaticResource GreenGradientStyle}"
                                CornerRadius="16" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="💡 Советы"
                                           FontWeight="Bold" FontSize="14"
                                           Foreground="White" Margin="0,0,0,10"/>
                                <TextBlock FontSize="12" Foreground="White" Opacity="0.92"
                                           TextWrapping="Wrap" Margin="0,0,0,8"
                                           Text="Используйте изображения высокого качества (1000×1000 px) для обложек — это повышает привлекательность трека."/>
                                <TextBlock FontSize="12" Foreground="White" Opacity="0.92"
                                           TextWrapping="Wrap" Margin="0,0,0,8"
                                           Text="Правильный жанр помогает алгоритмам рекомендаций показывать ваш трек нужной аудитории."/>
                                <TextBlock FontSize="12" Foreground="White" Opacity="0.92"
                                           TextWrapping="Wrap"
                                           Text="Регулярно загружайте треки, чтобы удерживать интерес слушателей."/>
                            </StackPanel>
                        </Border>

                        <!-- Stats card -->
                        <Border Background="White" CornerRadius="16" Padding="20"
                                BorderBrush="#E0DFD9" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Ваша статистика"
                                           FontWeight="Bold" FontSize="14"
                                           Foreground="#1A1A18" Margin="0,0,0,16"/>

                                <!-- Track count -->
                                <Border Background="#F5F4F0" CornerRadius="10"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock Text="🎵 Треков"
                                                   FontSize="12" Foreground="#888880"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatsTrackCount" Text="0"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="#1A1A18"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Total plays -->
                                <Border Background="#F5F4F0" CornerRadius="10"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock Text="▶ Прослушиваний"
                                                   FontSize="12" Foreground="#888880"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatsTotalPlays" Text="0"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="#1A1A18"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Total likes -->
                                <Border Background="#F5F4F0" CornerRadius="10"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <Grid>
                                        <TextBlock Text="♥ Лайков"
                                                   FontSize="12" Foreground="#888880"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatsTotalLikes" Text="0"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="#1A1A18"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Subscriber count -->
                                <Border Background="#F5F4F0" CornerRadius="10" Padding="14,12" Margin="10,0,0,0">
                                    <Grid>
                                        <TextBlock Text="👥 Подписчиков" FontSize="12" Foreground="#888880" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StatsSubscriberCount" Text="0" FontSize="18" FontWeight="Bold"
                                                   Foreground="#1A1A18" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Subscription chart card -->
                        <Border Background="White" CornerRadius="16" Padding="20" BorderBrush="#E0DFD9" BorderThickness="1" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Новые подписчики (14 дней)" FontWeight="Bold" FontSize="13"
                                           Foreground="#1A1A18" Margin="0,0,0,14"/>
                                <Canvas x:Name="SubscriberChartCanvas" Height="100"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Track detail panel (collapsed by default, overlaps default panel) -->
                    <Border x:Name="PanelTrackDetail"
                            Background="White" CornerRadius="16" Padding="20"
                            BorderBrush="#E0DFD9" BorderThickness="1"
                            Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- Back link -->
                                <TextBlock Text="← Назад к списку"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentColor}"
                                           Cursor="Hand" Margin="0,0,0,16"
                                           MouseLeftButtonDown="BackToDefault_Click"/>

                                <!-- Cover (120×120, centred) -->
                                <Border x:Name="TrackDetailCover"
                                        Width="120" Height="120"
                                        CornerRadius="12"
                                        Background="#B4C8B9"
                                        HorizontalAlignment="Center"
                                        ClipToBounds="True"
                                        Margin="0,0,0,16"/>

                                <!-- Title (FontSize=16, bold) -->
                                <TextBlock x:Name="TrackDetailTitle"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#1A1A18"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,0,0,4"/>

                                <!-- Artist (FontSize=12, muted) -->
                                <TextBlock x:Name="TrackDetailArtist"
                                           FontSize="12" Foreground="#888880"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <!-- Status badge -->
                                <Border x:Name="TrackStatusBadge"
                                        CornerRadius="8" Padding="12,6"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,20">
                                    <TextBlock x:Name="TrackStatusText"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </Border>

                                <!-- Stat boxes side by side -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#F5F4F0"
                                            CornerRadius="10" Padding="10,14">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="TrackDetailPlays"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="#1A1A18"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="▶ Прослушиваний"
                                                       FontSize="9" Foreground="#888880"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="#F5F4F0"
                                            CornerRadius="10" Padding="10,14">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="TrackDetailLikes"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="#1A1A18"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="♥ Лайков"
                                                       FontSize="9" Foreground="#888880"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Chart section -->
                                <Border Background="#F8F8F6" CornerRadius="12" Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="Прослушивания за 14 дней"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#888880"
                                                   Margin="0,0,0,10"/>
                                        <Canvas x:Name="ChartCanvas" Height="120"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

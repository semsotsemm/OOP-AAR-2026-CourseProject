<UserControl x:Class="Rewind.Tabs.UsersTabs.PlaylistDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:help="clr-namespace:Rewind.Helpers"
             mc:Ignorable="d"
             Height="auto" Width="auto">
    <Grid Background="{StaticResource BgMain}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,120">
                <Border Background="{StaticResource GreenGradientStyle}" CornerRadius="20" Padding="24" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="PlaylistTitleText" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="PlaylistMetaText" FontSize="13" Foreground="#FFFFFFCC" Margin="0,6,0,0"/>
                            <TextBlock x:Name="PlaylistStatsText" FontSize="13" Foreground="#FFFFFFCC" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Border Background="#1A1A18" CornerRadius="16" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="Back_Click">
                                <StackPanel Orientation="Horizontal" Margin="14,8">
                                    <Image Source="{help:Icon nav_back.png}" Width="12" Height="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Назад" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SaveBtn" Background="#1A1A18" CornerRadius="16" Cursor="Hand" MouseLeftButtonDown="SaveToMe_Click">
                                <TextBlock x:Name="SaveBtnText" Text="+ Добавить себе" Margin="14,8" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Треки плейлиста" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel x:Name="TracksContainer"/>
                <TextBlock x:Name="EmptyText" Text="В этом плейлисте пока нет треков" Visibility="Collapsed" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Tabs.UsersTabs.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BgMain}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,120">
                <TextBlock Foreground="{DynamicResource TextPrimary}" Text="Поиск" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>
                <Border Background="{DynamicResource BgSidebar}" CornerRadius="14" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" Margin="0,0,0,18">
                    <TextBox x:Name="SearchBox"
                             Height="46"
                             FontSize="14"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             Padding="16,0"
                             Tag="Треки, исполнители, плейлисты..."
                             TextChanged="SearchBox_TextChanged"
                             Style="{StaticResource SearchBoxStyle}"/>
                </Border>
                <!-- Sort row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border x:Name="SortTitle" CornerRadius="18" Padding="14,7" Cursor="Hand" Margin="0,0,8,0"
                            MouseLeftButtonDown="SortTitle_Click">
                        <Border.Background><SolidColorBrush Color="#1A1A18"/></Border.Background>
                        <TextBlock Text="По названию" FontSize="12" FontWeight="SemiBold" Foreground="White"
                                   FontFamily="{StaticResource HeaderFont}"/>
                    </Border>
                    <Border x:Name="SortArtist" CornerRadius="18" Padding="14,7" Cursor="Hand" Margin="0,0,8,0"
                            MouseLeftButtonDown="SortArtist_Click"
                            Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                        <TextBlock Text="По исполнителю" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}" FontFamily="{StaticResource HeaderFont}"/>
                    </Border>
                    <Border x:Name="SortDuration" CornerRadius="18" Padding="14,7" Cursor="Hand"
                            MouseLeftButtonDown="SortDuration_Click"
                            Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                        <TextBlock Text="По длительности" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}" FontFamily="{StaticResource HeaderFont}"/>
                    </Border>
                </StackPanel>

                <!-- ===== ФИЛЬТРЫ ПО ЖАНРАМ ===== -->
                <Grid Margin="0,0,0,20">
                    <Border x:Name="GenreDropdownBtn"
                            Background="{DynamicResource BgSidebar}"
                            CornerRadius="16"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1.5"
                            Padding="16,12"
                            Cursor="Hand"
                            MouseLeftButtonDown="ToggleGenreDropdown_Click">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🎛" FontSize="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Жанры" FontSize="13" FontWeight="Bold"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="GenreDropdownLabel"
                                               Text="Все жанры"
                                               FontSize="11"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="⌄" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentColor}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="GenreDropdownPopup"
                           PlacementTarget="{Binding ElementName=GenreDropdownBtn}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Width="520"
                                Background="{DynamicResource BgCard}"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1.5"
                                Padding="16"
                                Margin="0,8,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="5" Opacity="0.18"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Выберите один или несколько жанров" FontSize="13" FontWeight="Bold"
                                               FontFamily="{StaticResource HeaderFont}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Сброс" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentColor}"
                                               HorizontalAlignment="Right" Cursor="Hand"
                                               MouseLeftButtonDown="ClearGenreFilters_Click"/>
                                </Grid>
                                <WrapPanel x:Name="GenreFilters"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <StackPanel x:Name="ResultsContainer"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Tabs.UsersTabs.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BgMain}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,120">
                <TextBlock Foreground="{DynamicResource TextPrimary}" Text="Поиск" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>
                <Border Background="{DynamicResource BgSidebar}" CornerRadius="14" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" Margin="0,0,0,18">
                    <Grid Margin="10,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" 
                                   Width="18"
                                   Height="18"
                                   Fill="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   Cursor="Hand">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{help:Icon nav_search.png}" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                Height="46"
                                 FontSize="14"
                             Padding="6,0"
                                 FontFamily="{StaticResource BodyFont}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Tag="Поиск в любимых..."
                                 TextChanged="SearchBox_TextChanged"
                                 Style="{StaticResource SearchBoxStyle}"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                        <Border x:Name="GenreDropdownBtn"
                                Grid.Column="0"
                                Background="{DynamicResource BgSidebar}"
                                CornerRadius="16"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1.5"
                                Padding="16,12"
                                Cursor="Hand"
                                MouseLeftButtonDown="ToggleGenreDropdown_Click">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Жанры" FontSize="13" FontWeight="Bold"
                                                   FontFamily="{StaticResource HeaderFont}"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock x:Name="GenreDropdownLabel"
                                                   Text="Все жанры"
                                                   FontSize="11"
                                                   FontFamily="{StaticResource HeaderFont}"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="⌄" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentColor}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Popup x:Name="GenreDropdownPopup"
                               PlacementTarget="{Binding ElementName=GenreDropdownBtn}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Width="{Binding ActualWidth, ElementName=GenreDropdownBtn}"
                                    Background="{DynamicResource BgCard}"
                                    CornerRadius="18"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1.5"
                                    Padding="16"
                                    Margin="0,8,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" ShadowDepth="5" Opacity="0.18"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Выберите один или несколько жанров" FontSize="13" FontWeight="Bold"
                                                   FontFamily="{StaticResource HeaderFont}"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Сброс" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentColor}"
                                                   HorizontalAlignment="Right" Cursor="Hand"
                                                   MouseLeftButtonDown="ClearGenreFilters_Click"/>
                                    </Grid>
                                    <WrapPanel x:Name="GenreFilters"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    <!-- Сортировка -->
                    <Border Grid.Column="2" 
                            Background="{DynamicResource BgSidebar}"
                            CornerRadius="14" 
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1.5" 
                            Cursor="Hand"
                            MouseLeftButtonDown="ToggleSort_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <Rectangle x:Name="SortIcon"
                                       Width="18"
                                       Height="18"
                                       Margin="0,0,8,0"
                                       Fill="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"
                                       Cursor="Hand">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{help:Icon sort.png}" Stretch="Uniform"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock x:Name="SortLabel" Text="Недавние"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource HeaderFont}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Bottom" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <StackPanel x:Name="ResultsContainer"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Tabs.AdminTabs.TracksTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers">

    <Grid Background="{DynamicResource BgMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ЗАГОЛОВОК + ПОИСК ===== -->
        <StackPanel Grid.Row="0" Margin="28,24,28,16">
            <TextBlock Text="Треки" FontSize="28" FontWeight="Bold"
                       FontFamily="{StaticResource HeaderFont}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Статистика треков платформы" FontSize="13"
                       FontFamily="{StaticResource HeaderFont}"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,16"/>

            <!-- Поиск -->
            <Border Background="{DynamicResource BgCard}" CornerRadius="14"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{help:Icon nav_search.png}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" x:Name="SearchBox"
                             Height="46" FontSize="14"
                             FontFamily="{StaticResource BodyFont}"
                             Foreground="{DynamicResource TextPrimary}"
                             Background="Transparent" BorderThickness="0"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <TextBlock x:Name="Placeholder"
                                                           Text="Поиск по названию или исполнителю..."
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Text" Value=""/>
                                                        <Condition Property="IsFocused" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </Border>

            <!-- Фильтры статуса -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border x:Name="FilterAll" CornerRadius="20" Padding="14,7" Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="FilterAll_Click">
                    <Border.Background><SolidColorBrush Color="#1A1A18"/></Border.Background>
                    <TextBlock Text="Все" FontSize="12" FontWeight="SemiBold" Foreground="White"
                               FontFamily="{StaticResource HeaderFont}"/>
                </Border>
                <Border x:Name="FilterPublished" CornerRadius="20" Padding="14,7" Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="FilterPublished_Click"
                        Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                    <TextBlock Text="Опубликованные" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}" FontFamily="{StaticResource HeaderFont}"/>
                </Border>
                <Border x:Name="FilterPending" CornerRadius="20" Padding="14,7" Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="FilterPending_Click"
                        Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                    <TextBlock Text="На проверке" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}" FontFamily="{StaticResource HeaderFont}"/>
                </Border>
                <Border x:Name="FilterBanned" CornerRadius="20" Padding="14,7" Cursor="Hand"
                        MouseLeftButtonDown="FilterBanned_Click"
                        Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                    <TextBlock Text="Заблокированные" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}" FontFamily="{StaticResource HeaderFont}"/>
                </Border>
            </StackPanel>

            <!-- Шапка таблицы -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}" Margin="4,0"/>
                <TextBlock Grid.Column="1" Text="ТРЕК" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="2" Text="ИСПОЛНИТЕЛЬ" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}"/>
                <TextBlock Grid.Column="3" Text="ЗАГРУЖЕН" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}"/>
                <TextBlock Grid.Column="4" Text="► PLAYS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}"/>
                <TextBlock Grid.Column="5" Text="♥ LIKES" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}"/>
                <TextBlock Grid.Column="6" Text="ДЕЙСТВИЯ" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextMuted}"
                           FontFamily="{StaticResource HeaderFont}"/>
            </Grid>
        </StackPanel>

        <!-- ===== СПИСОК ТРЕКОВ ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="28,0,28,28">
            <StackPanel x:Name="TracksContainer"/>
        </ScrollViewer>
    </Grid>
</UserControl>

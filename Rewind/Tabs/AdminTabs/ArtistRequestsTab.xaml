<UserControl x:Class="Rewind.Tabs.AdminTabs.ArtistRequestsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ApproveBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RejectBtn" TargetType="Button" BasedOn="{StaticResource ApproveBtn}">
            <Setter Property="Background" Value="#FFEAEA"/>
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ЗАГОЛОВОК ===== -->
        <StackPanel Grid.Row="0" Margin="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Заявки исполнителей" FontSize="28" FontWeight="Bold"
                               FontFamily="{StaticResource HeaderFont}"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="PendingCountText"
                                   Text="Загрузка..." FontSize="13"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Фильтры -->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Border x:Name="FilterPending" CornerRadius="20" Padding="16,8"
                        Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="FilterPending_Click">
                    <Border.Background>
                        <SolidColorBrush x:Name="FilterPendingBg" Color="#1A1A18"/>
                    </Border.Background>
                    <TextBlock Text="Ожидают" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}" Foreground="White"/>
                </Border>
                <Border x:Name="FilterAll" CornerRadius="20" Padding="16,8"
                        Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="FilterAll_Click"
                        Background="{DynamicResource BgCard}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                    <TextBlock Text="Все" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Border>
                <Border x:Name="FilterApproved" CornerRadius="20" Padding="16,8"
                        Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="FilterApproved_Click"
                        Background="{DynamicResource BgCard}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                    <TextBlock Text="Одобренные" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Border>
                <Border x:Name="FilterRejected" CornerRadius="20" Padding="16,8"
                        Cursor="Hand"
                        MouseLeftButtonDown="FilterRejected_Click"
                        Background="{DynamicResource BgCard}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                    <TextBlock Text="Отклонённые" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource HeaderFont}"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ===== СПИСОК ЗАЯВОК ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="28,0,28,28">
            <StackPanel>
                <!-- Пустое состояние -->
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        Background="{DynamicResource BgCard}" CornerRadius="16"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        Padding="40" Margin="0,10,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="EmptyStateText" Text="Нет ожидающих заявок"
                                   FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Когда исполнители подадут заявку на регистрацию, они появятся здесь"
                                   FontSize="13" FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Карточки заявок -->
                <StackPanel x:Name="RequestsContainer"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Tabs.AdminTabs.TrackSubmissionsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers">

    <Grid Background="{DynamicResource BgMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="28,24,28,16">
            <TextBlock Text="Треки на проверку" FontSize="28" FontWeight="Bold"
                       FontFamily="{StaticResource HeaderFont}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock x:Name="PendingCountText" Text="Загрузка..." FontSize="13"
                       FontFamily="{StaticResource HeaderFont}"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="28,0,28,28">
            <StackPanel>
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        Background="{DynamicResource BgCard}" CornerRadius="16"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        Padding="40">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="{help:Icon music_note.png}" Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.6"/>
                        <TextBlock Text="Нет треков на проверке" FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Когда исполнители загрузят треки, они появятся здесь для проверки"
                                   FontSize="13" FontFamily="{StaticResource HeaderFont}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="TracksContainer"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Модальное окно отклонения -->
        <Grid x:Name="RejectModal" Visibility="Collapsed" Panel.ZIndex="100"
              Grid.Row="0" Grid.RowSpan="2">
            <Rectangle Fill="#88000000"/>
            <Border Background="{DynamicResource BgCard}" CornerRadius="20"
                    Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="32">
                <StackPanel>
                    <TextBlock Text="Причина отклонения" FontSize="20" FontWeight="Bold"
                               FontFamily="{StaticResource HeaderFont}"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Укажите причину — она будет видна исполнителю"
                               FontSize="13" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="{StaticResource HeaderFont}" Margin="0,0,0,20"/>
                    <TextBox x:Name="RejectReasonBox" Height="100"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="13" Padding="12"
                             FontFamily="{StaticResource BodyFont}"
                             Foreground="{DynamicResource TextPrimary}"
                             Background="{DynamicResource BgCardHover}"
                             BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelRejectBtn" Content="Отмена"
                                Click="CancelReject_Click"
                                Background="{DynamicResource BgCardHover}"
                                Foreground="{DynamicResource TextSecondary}"
                                FontSize="13" FontWeight="SemiBold"
                                BorderThickness="0" Padding="18,10" Margin="0,0,12,0"
                                Cursor="Hand"/>
                        <Button x:Name="ConfirmRejectBtn" Content="Отклонить трек"
                                Click="ConfirmReject_Click"
                                Background="#FFEAEA" Foreground="#C62828"
                                FontSize="13" FontWeight="SemiBold"
                                BorderThickness="0" Padding="18,10"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Contols.PlaylistItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignWidth="800">

    <Border Background="#121212" CornerRadius="8" Margin="5" Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="100" Height="100" CornerRadius="4" ClipToBounds="True">
                <Image Source="{Binding CoverPath}" Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding AuthorName}" Margin="8,0,0,0" 
                               Foreground="#888" VerticalAlignment="Center" FontSize="14"/>
                    <TextBlock Text="{Binding DateUploaded}" Margin="15,0,0,0" 
                               Foreground="#555" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <TextBlock Text="{Binding TrackTitle}" Margin="0,5,0,0"
                           Foreground="White" FontSize="18" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="15,0,0,0">
                <Button Style="{StaticResource ActionButtonStyle}">
                    <Image Source="{help:Icon download.png}" Width="12" Height="12"/>
                </Button>
                <Button Style="{StaticResource ActionButtonStyle}" Margin="8,0">
                    <Image Source="{help:Icon remove.png}" Width="14" Height="14"/>
                </Button>
                <Button Style="{StaticResource ActionButtonStyle}">
                    <Image Source="{help:Icon trash.png}" Width="14" Height="14"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,5,5">
                <Image Source="{help:Icon like_outline.png}" Width="14" Height="14" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding LikeCount}" Foreground="#555" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
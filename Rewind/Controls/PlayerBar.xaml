<UserControl x:Class="Rewind.Contols.PlayerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             x:Name="thisPlayer"
             Visibility="Collapsed">
    <Border BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0">
        <Border.Background>
            <SolidColorBrush Color="#1A1A18" Opacity="0.95"/>
        </Border.Background>

        <Grid Margin="24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="150"/>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="1*" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            </StackPanel>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Button Content="⇄" Style="{StaticResource PlayerControlBtnStyle}"/>
                    <Button Content="⏮" Style="{StaticResource PlayerControlBtnStyle}" Click="PreviousButton_Click"/>
                    <Button Click="PlayButton_Click" Background="Transparent" BorderThickness="0" Margin="10,0">
                        <Border Width="40" Height="40" Background="White" CornerRadius="20">
                            <TextBlock Text="{Binding PlayPauseIcon, ElementName=thisPlayer}" 
                                       FontSize="16" Foreground="#1A1A18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                    <Button Content="⏭" Style="{StaticResource PlayerControlBtnStyle}" Click="NextButton_Click"/>
                    <Button Content="↺" Style="{StaticResource PlayerControlBtnStyle}"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding CurrentTimeStr, ElementName=thisPlayer}" 
                               Foreground="#888880" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <Slider x:Name="MusicSlider"
                            Style="{StaticResource SliderStyle}"
                            Grid.Column="1" 
                            Minimum="0"
                            Maximum="{Binding TotalSeconds, ElementName=thisPlayer}"
                            Value="{Binding CurrentSeconds, ElementName=thisPlayer, Mode=TwoWay}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center" 
                            Margin="10,0"
                            PreviewMouseDown="MusicSlider_PreviewMouseDown"
                            PreviewMouseUp="MusicSlider_PreviewMouseUp"/>

                    <TextBlock Grid.Column="2" Text="{Binding TotalTimeStr, ElementName=thisPlayer}" 
                               Foreground="#888880" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
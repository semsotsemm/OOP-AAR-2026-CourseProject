<UserControl x:Class="Rewind.Contols.PlayerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Name="thisPlayer"
             Background="{DynamicResource PlayerBg}"
             Visibility="Collapsed">
    <Grid>

        <!-- ═══ Content ═══ -->
        <Grid Margin="24,0" Height="76">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="180"/>
                <ColumnDefinition Width="2*" MinWidth="280"/>
                <ColumnDefinition Width="1*" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: cover + track info ── -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Mini cover — клик открывает NowPlaying -->
                <Border x:Name="CoverBorder" Width="44" Height="44" CornerRadius="8"
                        Margin="0,0,12,0" ClipToBounds="True"
                        Background="#2A2A28" Cursor="Hand"
                        MouseLeftButtonDown="PlayerInfo_Click">
                    <Grid>
                        <Image x:Name="CoverImage" Stretch="UniformToFill"/>
                        <Image Source="{help:Icon music_note.png}" x:Name="CoverPlaceholder"
                               Width="18" Height="18" Opacity="0.5"/>
                    </Grid>
                </Border>

                <!-- Title + artist -->
                <StackPanel VerticalAlignment="Center" MaxWidth="200">
                    <!-- Название — клик открывает NowPlaying -->
                    <TextBlock Text="{Binding CurrentTrack, ElementName=thisPlayer}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               MouseLeftButtonDown="PlayerInfo_Click"/>
                    <!-- Исполнитель — клик открывает страницу исполнителя -->
                    <TextBlock Text="{Binding CurrentArtist, ElementName=thisPlayer}"
                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               MouseLeftButtonDown="ArtistName_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- ── Centre: controls + slider ── -->
            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Transport buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Button x:Name="ShuffleBtn" Style="{StaticResource PlayerControlBtnStyle}" Click="ShuffleButton_Click">
                        <Image x:Name="ShuffleIcon" Source="{help:Icon player_shuffle.png}" Width="14" Height="14"/>
                    </Button>
                    <Button Style="{StaticResource PlayerControlBtnStyle}" Click="PreviousButton_Click">
                        <Image Source="{help:Icon player_prev.png}" Width="14" Height="14"/>
                    </Button>

                    <!-- Play/Pause circle -->
                    <Button Click="PlayButton_Click" Background="Transparent"
                            BorderThickness="0" Margin="8,0">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{DynamicResource AccentColor}">
                            <Rectangle x:Name="PlayPauseBtn"
                                       Width="14" Height="14"
                                       Fill="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Cursor="Hand">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{Binding PlayPauseIcon, ElementName=thisPlayer}"
                                                Stretch="Uniform"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </Border>
                    </Button>

                    <Button Style="{StaticResource PlayerControlBtnStyle}" Click="NextButton_Click">
                        <Image Source="{help:Icon player_next.png}" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="RepeatBtn" Style="{StaticResource PlayerControlBtnStyle}" Click="RepeatButton_Click">
                        <Image x:Name="RepeatIcon" Source="{help:Icon player_repeat.png}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>

                <!-- Progress bar -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentTimeStr, ElementName=thisPlayer}"
                               Foreground="#666660" FontSize="10"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <Slider x:Name="MusicSlider"
                            Style="{StaticResource SliderStyle}"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="{Binding TotalSeconds, ElementName=thisPlayer}"
                            Value="{Binding CurrentSeconds, ElementName=thisPlayer, Mode=TwoWay}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            Margin="8,0"
                            PreviewMouseDown="MusicSlider_PreviewMouseDown"
                            PreviewMouseUp="MusicSlider_PreviewMouseUp"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding TotalTimeStr, ElementName=thisPlayer}"
                               Foreground="#666660" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- ── Right: volume + like ── -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,4,0">

                <!-- Volume icon -->
                <Image Source="{help:Icon volume.png}" Width="14" Height="14"
                       Opacity="0.6" Margin="0,0,8,0" VerticalAlignment="Center"/>

                <!-- Volume slider -->
                <Slider x:Name="VolumeSlider"
                        Style="{StaticResource SliderStyle}"
                        Width="80"
                        Minimum="0" Maximum="1" Value="1"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        ValueChanged="VolumeSlider_ValueChanged"/>

                <!-- Like button -->
                <Border Width="32" Height="32" CornerRadius="16"
                        Background="#252523" Cursor="Hand"
                        MouseLeftButtonDown="LikeBtn_Click">
                    <Rectangle x:Name="LikeIcon"
                               Width="14" Height="14"
                               Fill="{DynamicResource AccentColor}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                        <Rectangle.OpacityMask>
                            <ImageBrush x:Name="LikeIconBrush"
                                        ImageSource="{help:Icon like_outline.png}"
                                        Stretch="Uniform"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Rewind.Contols.AlbumCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             x:Name="thisCard">
    <Border Style="{StaticResource AlbumCardStyle}">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.2"
                          BlurRadius="14" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <Border Height="110" CornerRadius="10" Margin="0,0,0,12" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{Binding StartColor, ElementName=thisCard}" Offset="0"/>
                        <GradientStop Color="{Binding EndColor, ElementName=thisCard}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Image Source="{help:Icon music_note.png}" Width="36" Height="36" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Image Source="{Binding CoverImageSource, ElementName=thisCard}" 
                       Stretch="UniformToFill"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding AlbumTitle, ElementName=thisCard}" 
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>

            <TextBlock Text="{Binding Artist, ElementName=thisCard}" 
                   FontSize="11" Foreground="{DynamicResource TextMuted}"
                   Margin="0,3,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
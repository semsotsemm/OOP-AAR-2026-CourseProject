<UserControl x:Class="Rewind.Contols.TrackItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="this"
             d:DesignWidth="800">

    <Border Style="{StaticResource TrackCardStyle}" MouseLeftButtonDown="TrackCard_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.2" BlurRadius="12" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="10" Margin="0,0,14,0" Background="{StaticResource BgCard}">
                <Grid>
                    <Border CornerRadius="10">
                        <Border.Background>
                            <ImageBrush x:Name="TrackCoverBrush" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <Image x:Name="CoverPlaceholder" Source="{help:Icon music_note.png}" Width="20" Height="20" Opacity="0.7"/>
                </Grid>
            </Border>
            <!-- Название и артист -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TrackTitleText" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="ArtistNameText" FontSize="12" Foreground="{DynamicResource TextMuted}"
                           Margin="0,3,0,0" Cursor="Hand"
                           MouseLeftButtonDown="ArtistName_Click"/>
            </StackPanel>


            <!-- Длительность и плей -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Кнопка в плейлист -->
                <Border Grid.Column="3" Width="36" Height="36" CornerRadius="18"
                        Background="{DynamicResource BgCardHover}" Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="AddToPlaylist_Click"
                        ToolTip="Добавить в плейлист">
                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Играть следующим -->
                <Border x:Name="PlayNextBtn" Width="36" Height="36" CornerRadius="18"
                        Background="{DynamicResource BgCardHover}" Cursor="Hand" Margin="0,0,8,0"
                        MouseLeftButtonDown="PlayNext_Click"
                        ToolTip="Играть следующим">
                    <TextBlock Text="⇥" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Button x:Name="PlayBtn" Style="{StaticResource PlayButtonStyle}" Click="Play_Click"
                        Width="36" Height="36">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Width="36" Height="36" CornerRadius="18"
                                    Background="{StaticResource AccentColor}" Cursor="Hand">
                                <Image x:Name="PlayIcon" Source="{help:Icon player_play.png}" Width="12" Height="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Rectangle x:Name="LikeBtn"
                           Grid.Column="2"
                           Width="20"
                           Height="20"
                           Fill="{StaticResource AccentColor}"
                           VerticalAlignment="Center"
                           Margin="16,0,16,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="LikeBtn_Click">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="{help:Icon like_outline.png}"
                                    x:Name="LikeIcon"
                                    Stretch="Uniform"/>
                    </Rectangle.OpacityMask>
                </Rectangle>

                <TextBlock x:Name="DurationText" Text="0:00" FontSize="12" Foreground="{DynamicResource TextMuted}"
           VerticalAlignment="Center" Margin="0,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

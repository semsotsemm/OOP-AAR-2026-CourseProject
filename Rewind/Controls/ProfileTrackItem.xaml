<UserControl x:Class="Rewind.Contols.ProfileTrackItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Rewind.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="400">

    <Grid Background="{StaticResource BgCard}" Margin="0,2">

        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1AFFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="3" Margin="0,0,10,0">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding CoverPath}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding ArtistName}" 
                           FontSize="10" 
                           Foreground="#999" 
                           Margin="0,0,0,1"/>

                <TextBlock Text="{Binding TrackTitle}" 
                           FontSize="13" 
                           FontWeight="Medium" 
                           Foreground="White" 
                           Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Orientation="Horizontal" Opacity="0.8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                        <Image Source="{help:Icon chart.png}" Width="9" Height="9" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding PlaysCount}" FontSize="9" Foreground="#999"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                        <Image Source="{help:Icon like_outline.png}" Width="9" Height="9" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding LikesCount}" FontSize="9" Foreground="#999"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="Rewind.Contols.ProfileTrackItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="400">

    <Grid Background="{StaticResource BgCard}" Margin="0,2">

        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1AFFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="3" Margin="0,0,10,0">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding CoverPath}" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding ArtistName}" 
                           FontSize="10" 
                           Foreground="#999" 
                           Margin="0,0,0,1"/>

                <TextBlock Text="{Binding TrackTitle}" 
                           FontSize="13" 
                           FontWeight="Medium" 
                           Foreground="White" 
                           Margin="0,0,0,4"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Orientation="Horizontal" Opacity="0.8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                        <Path Data="M3 14 L3 1 L5 1 L5 14 Z M7 14 L7 5 L9 5 L9 14 Z M11 14 L11 8 L13 8 L13 14 Z" 
                              Fill="#999" Stretch="Uniform" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding PlaysCount}" FontSize="9" Foreground="#999"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                        <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" 
                              Fill="#999" Stretch="Uniform" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding LikesCount}" FontSize="9" Foreground="#999"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
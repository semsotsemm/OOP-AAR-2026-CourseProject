<Application x:Class="Rewind.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Rewind"
             StartupUri="Pages/Registration.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Buttons.xaml"/>
                <ResourceDictionary Source="/Resources/Cards.xaml"/>
                <ResourceDictionary Source="/Resources/Fonts.xaml"/>
                <ResourceDictionary Source="/Resources/ScrollBars.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/ThemeClassic.xaml"/>
                <ResourceDictionary Source="/Resources/Animation.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
